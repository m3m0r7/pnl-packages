{
  "schema_version": "2026-07-01",
  "name": "libnetcdf/libnetcdf",
  "version": "4.9.2",
  "description": "PHP FFI wrapper for Unidata netCDF self-describing array data.",
  "authors": [
    {
      "name": "Unidata / netCDF maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnetcdf\\Libnetcdf",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install netcdf"
      ],
      "checkIfExists": [
        "brew list netcdf"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libnetcdf-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists netcdf"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libnetcdf-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists netcdf"
      ]
    },
    "alpine": {
      "install": [
        "apk add netcdf-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists netcdf"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y netcdf-devel"
      ],
      "checkIfExists": [
        "rpm -q netcdf-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y netcdf-devel"
      ],
      "checkIfExists": [
        "rpm -q netcdf-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install netcdf-c"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "netcdf": {
      "symbol_prefix": "nc",
      "library_names": [
        "libnetcdf.dylib",
        "libnetcdf.so",
        "netcdf.dll"
      ],
      "header_names": [
        "netcdf.h"
      ],
      "version": ">=4.6.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
