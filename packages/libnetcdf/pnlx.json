{
  "schema_version": "2026-07-01",
  "name": "libnetcdf/libnetcdf",
  "version": "4.9.2",
  "description": "PHP FFI wrapper for Unidata netCDF self-describing array data.",
  "authors": [
    {
      "name": "Unidata / netCDF maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnetcdf\\Libnetcdf",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-error-and-type-info.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "netcdf": {
      "symbol_prefix": "nc",
      "library_names": [
        "libnetcdf.dylib",
        "libnetcdf.so",
        "netcdf.dll"
      ],
      "header_names": [
        "netcdf.h"
      ],
      "version": ">=4.6.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install netcdf"
        ],
        "check_if_exists": [
          "brew list netcdf"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libnetcdf-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists netcdf"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libnetcdf-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists netcdf"
        ]
      },
      "alpine": {
        "commands": [
          "apk add netcdf-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists netcdf"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y netcdf-devel"
        ],
        "check_if_exists": [
          "rpm -q netcdf-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y netcdf-devel"
        ],
        "check_if_exists": [
          "rpm -q netcdf-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install netcdf-c"
        ]
      }
    }
  }
}
