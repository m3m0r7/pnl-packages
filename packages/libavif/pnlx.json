{
  "schema_version": "2026-07-01",
  "name": "libavif/libavif",
  "version": "1.0.4",
  "description": "PHP FFI wrapper for the libavif AVIF codec.",
  "authors": [
    {
      "name": "libavif maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libavif\\Libavif",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-formats.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libavif": {
      "symbol_prefix": "avif",
      "library_names": [
        "libavif.dylib",
        "libavif.so",
        "avif.dll"
      ],
      "header_names": [
        "avif/avif.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libavif"
        ],
        "check_if_exists": [
          "brew list libavif"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libavif-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavif"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libavif-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavif"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libavif-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavif"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libavif-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavif"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libavif-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavif"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libavif"
        ]
      }
    }
  }
}
