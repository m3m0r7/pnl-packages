{
  "schema_version": "2026-07-01",
  "name": "liblzma/liblzma",
  "version": "5.6.1",
  "description": "PHP FFI wrapper for the xz/liblzma compression library.",
  "authors": [
    {
      "name": "xz / liblzma maintainers"
    }
  ],
  "license": "0BSD",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Liblzma\\Liblzma",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-utilities.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "liblzma": {
      "symbol_prefix": "lzma",
      "library_names": [
        "liblzma.dylib",
        "liblzma.so",
        "lzma.dll"
      ],
      "header_names": [
        "lzma.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install xz"
        ],
        "check_if_exists": [
          "brew list xz"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y liblzma-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists liblzma"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y liblzma-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists liblzma"
        ]
      },
      "alpine": {
        "commands": [
          "apk add xz-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists liblzma"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y xz-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists liblzma"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y xz-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists liblzma"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install liblzma"
        ]
      }
    }
  }
}
