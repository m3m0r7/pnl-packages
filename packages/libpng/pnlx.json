{
  "schema_version": "2026-07-01",
  "name": "libpng/libpng",
  "version": "1.6.43",
  "description": "PHP FFI wrapper for libpng image codec.",
  "authors": [
    {
      "name": "libpng maintainers"
    }
  ],
  "license": "libpng-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpng\\Libpng",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libpng": {
      "symbol_prefix": "png",
      "library_names": [
        "libpng.dylib",
        "libpng16.so",
        "libpng16.dll"
      ],
      "header_names": [
        "png.h",
        "pngconf.h"
      ],
      "version": ">=1.6.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libpng"
        ],
        "check_if_exists": [
          "brew list libpng"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpng-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libpng"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpng-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libpng"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libpng-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libpng"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libpng-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libpng"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libpng-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libpng"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libpng"
        ]
      }
    }
  }
}
