{
  "schema_version": "2026-07-01",
  "name": "libpng/libpng",
  "version": "1.6.43",
  "description": "PHP FFI wrapper for libpng image codec.",
  "authors": [
    {
      "name": "libpng maintainers"
    }
  ],
  "license": "libpng-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpng\\Libpng",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libpng"
      ],
      "checkIfExists": [
        "brew list libpng"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libpng-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libpng"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libpng-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libpng"
      ]
    },
    "alpine": {
      "install": [
        "apk add libpng-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libpng"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libpng-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libpng"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libpng-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libpng"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libpng"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libpng": {
      "symbol_prefix": "png",
      "library_names": [
        "libpng.dylib",
        "libpng16.so",
        "libpng16.dll"
      ],
      "header_names": [
        "png.h",
        "pngconf.h"
      ],
      "version": ">=1.6.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
