{
  "schema_version": "2026-07-01",
  "name": "libtidy/libtidy",
  "version": "5.8.0",
  "description": "PHP FFI wrapper for HTML Tidy.",
  "authors": [
    {
      "name": "HTML Tidy maintainers"
    }
  ],
  "license": "W3C",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtidy\\Libtidy",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libtidy": {
      "symbol_prefix": "tidy",
      "library_names": [
        "libtidy.dylib",
        "libtidy.so",
        "tidy.dll"
      ],
      "header_names": [
        "tidy.h",
        "tidybuffio.h",
        "tidy/tidy.h",
        "tidy/tidybuffio.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install tidy-html5"
        ],
        "check_if_exists": [
          "brew list tidy-html5"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtidy-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libtidy.so"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtidy-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libtidy.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add tidyhtml-dev"
        ],
        "check_if_exists": [
          "apk info -e tidyhtml-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libtidy-devel"
        ],
        "check_if_exists": [
          "rpm -q libtidy-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libtidy-devel"
        ],
        "check_if_exists": [
          "rpm -q libtidy-devel"
        ]
      }
    }
  }
}
