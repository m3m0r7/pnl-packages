{
  "schema_version": "2026-07-01",
  "name": "libavcodec/libavcodec",
  "version": "61.3.100",
  "description": "PHP FFI wrapper for FFmpeg libavcodec.",
  "authors": [
    {
      "name": "FFmpeg libavcodec maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libavcodec\\Libavcodec",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-codec-names.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libavcodec": {
      "symbol_prefix": "avcodec",
      "library_names": [
        "libavcodec.dylib",
        "libavcodec.so",
        "avcodec.dll"
      ],
      "header_names": [
        "libavcodec/avcodec.h"
      ],
      "version": ">=58.0.0 & <62.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ffmpeg"
        ],
        "check_if_exists": [
          "brew list ffmpeg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libavcodec-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavcodec"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libavcodec-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavcodec"
        ]
      },
      "alpine": {
        "commands": [
          "apk add ffmpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavcodec"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavcodec"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavcodec"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install ffmpeg"
        ]
      }
    }
  }
}
