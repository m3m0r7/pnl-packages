{
  "schema_version": "2026-07-01",
  "name": "libquickjs/libquickjs",
  "version": "0.8.0",
  "description": "PHP FFI wrapper for the QuickJS JavaScript engine.",
  "authors": [
    {
      "name": "QuickJS maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libquickjs\\Libquickjs",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install quickjs"
      ],
      "checkIfExists": [
        "brew list quickjs"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y quickjs"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libquickjs"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y quickjs"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libquickjs"
      ]
    },
    "alpine": {
      "install": [
        "apk add quickjs-dev"
      ],
      "checkIfExists": [
        "apk info -e quickjs-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y quickjs-devel"
      ],
      "checkIfExists": [
        "rpm -q quickjs-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y quickjs-devel"
      ],
      "checkIfExists": [
        "rpm -q quickjs-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libquickjs": {
      "symbol_prefix": "JS",
      "library_names": [
        "libquickjs.dylib",
        "libquickjs.so",
        "quickjs.dll"
      ],
      "header_names": [
        "quickjs.h"
      ],
      "version": ">=0.1.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
