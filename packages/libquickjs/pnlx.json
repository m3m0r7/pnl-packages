{
  "schema_version": "2026-07-01",
  "name": "libquickjs/libquickjs",
  "version": "0.8.0",
  "description": "PHP FFI wrapper for the QuickJS JavaScript engine.",
  "authors": [
    {
      "name": "QuickJS maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libquickjs\\Libquickjs",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64",
      "libc": "musl"
    },
    {
      "os": "linux",
      "arch": "aarch64",
      "libc": "musl"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libquickjs": {
      "symbol_prefix": "JS",
      "library_names": [
        "libquickjs.dylib",
        "libquickjs.so",
        "quickjs.dll"
      ],
      "header_names": [
        "quickjs.h",
        "quickjs/quickjs.h"
      ],
      "version": ">=0.1.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install quickjs"
        ],
        "check_if_exists": [
          "brew list quickjs"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y quickjs"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libquickjs"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y quickjs"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libquickjs"
        ]
      },
      "alpine": {
        "commands": [
          "apk add quickjs-dev"
        ],
        "check_if_exists": [
          "apk info -e quickjs-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y quickjs-devel"
        ],
        "check_if_exists": [
          "rpm -q quickjs-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y quickjs-devel"
        ],
        "check_if_exists": [
          "rpm -q quickjs-devel"
        ]
      }
    }
  }
}
