{
  "schema_version": "2026-07-01",
  "name": "libuuid/libuuid",
  "version": "2.40",
  "description": "PHP FFI wrapper for libuuid.",
  "authors": [
    {
      "name": "util-linux libuuid maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libuuid\\Libuuid",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libuuid": {
      "symbol_prefix": "uuid",
      "library_names": [
        "libuuid.dylib",
        "libuuid.so",
        "uuid.dll"
      ],
      "header_names": [
        "uuid/uuid.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ossp-uuid"
        ],
        "check_if_exists": [
          "brew list ossp-uuid"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y uuid-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists uuid"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y uuid-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists uuid"
        ]
      },
      "alpine": {
        "commands": [
          "apk add util-linux-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists uuid"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libuuid-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists uuid"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libuuid-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists uuid"
        ]
      }
    }
  }
}
