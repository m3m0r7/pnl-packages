{
  "schema_version": "2026-07-01",
  "name": "libjxl/libjxl",
  "version": "0.10.2",
  "description": "PHP FFI wrapper for libjxl JPEG XL encoding and decoding.",
  "authors": [
    {
      "name": "libjxl maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libjxl\\Libjxl",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-encoder-quality.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libjxl": {
      "symbol_prefix": "Jxl",
      "library_names": [
        "libjxl.dylib",
        "libjxl.so",
        "jxl.dll"
      ],
      "header_names": [
        "jxl/decode.h",
        "jxl/encode.h"
      ],
      "version": ">=0.7.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install jpeg-xl"
        ],
        "check_if_exists": [
          "brew list jpeg-xl"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libjxl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libjxl"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libjxl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libjxl"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libjxl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libjxl"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libjxl-devel"
        ],
        "check_if_exists": [
          "rpm -q libjxl-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libjxl-devel"
        ],
        "check_if_exists": [
          "rpm -q libjxl-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libjxl"
        ]
      }
    }
  }
}
