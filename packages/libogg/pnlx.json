{
  "schema_version": "2026-07-01",
  "name": "libogg/libogg",
  "version": "1.3.5",
  "description": "PHP FFI wrapper for the Ogg container library.",
  "authors": [
    {
      "name": "Ogg maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libogg\\Libogg",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-bitpacker.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libogg": {
      "symbol_prefix": "ogg",
      "library_names": [
        "libogg.dylib",
        "libogg.so",
        "ogg.dll"
      ],
      "header_names": [
        "ogg/ogg.h"
      ],
      "version": ">=1.3.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libogg"
        ],
        "check_if_exists": [
          "brew list libogg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libogg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists ogg"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libogg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists ogg"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libogg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists ogg"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libogg-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists ogg"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libogg-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists ogg"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libogg"
        ]
      }
    }
  }
}
