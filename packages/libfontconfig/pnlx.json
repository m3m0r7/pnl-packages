{
  "schema_version": "2026-07-01",
  "name": "libfontconfig/libfontconfig",
  "version": "2.15.0",
  "description": "PHP FFI wrapper for fontconfig font configuration and matching.",
  "authors": [
    {
      "name": "fontconfig maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libfontconfig\\Libfontconfig",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install fontconfig"
      ],
      "checkIfExists": [
        "brew list fontconfig"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libfontconfig1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists fontconfig"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libfontconfig1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists fontconfig"
      ]
    },
    "alpine": {
      "install": [
        "apk add fontconfig-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists fontconfig"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y fontconfig-devel"
      ],
      "checkIfExists": [
        "rpm -q fontconfig-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y fontconfig-devel"
      ],
      "checkIfExists": [
        "rpm -q fontconfig-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install fontconfig"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "fontconfig": {
      "symbol_prefix": "Fc",
      "library_names": [
        "libfontconfig.dylib",
        "libfontconfig.so",
        "fontconfig.dll"
      ],
      "header_names": [
        "fontconfig/fontconfig.h"
      ],
      "version": ">=2.12.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
