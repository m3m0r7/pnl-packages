{
  "schema_version": "2026-07-01",
  "name": "libfontconfig/libfontconfig",
  "version": "2.15.0",
  "description": "PHP FFI wrapper for fontconfig font configuration and matching.",
  "authors": [
    {
      "name": "fontconfig maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libfontconfig\\Libfontconfig",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-weight.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "fontconfig": {
      "symbol_prefix": "Fc",
      "library_names": [
        "libfontconfig.dylib",
        "libfontconfig.so",
        "fontconfig.dll"
      ],
      "header_names": [
        "fontconfig/fontconfig.h"
      ],
      "version": ">=2.12.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install fontconfig"
        ],
        "check_if_exists": [
          "brew list fontconfig"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libfontconfig1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists fontconfig"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libfontconfig1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists fontconfig"
        ]
      },
      "alpine": {
        "commands": [
          "apk add fontconfig-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists fontconfig"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y fontconfig-devel"
        ],
        "check_if_exists": [
          "rpm -q fontconfig-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y fontconfig-devel"
        ],
        "check_if_exists": [
          "rpm -q fontconfig-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install fontconfig"
        ]
      }
    }
  }
}
