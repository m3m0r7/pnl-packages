{
  "schema_version": "2026-07-01",
  "name": "libtiff/libtiff",
  "version": "4.6.0",
  "description": "PHP FFI wrapper for libtiff image codec.",
  "authors": [
    {
      "name": "libtiff maintainers"
    }
  ],
  "license": "libtiff",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtiff\\Libtiff",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-datawidth.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libtiff": {
      "symbol_prefix": "TIFF",
      "library_names": [
        "libtiff.dylib",
        "libtiff.so",
        "tiff.dll"
      ],
      "header_names": [
        "tiffio.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libtiff"
        ],
        "check_if_exists": [
          "brew list libtiff"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtiff-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libtiff-4"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtiff-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libtiff-4"
        ]
      },
      "alpine": {
        "commands": [
          "apk add tiff-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libtiff-4"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libtiff-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libtiff-4"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libtiff-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libtiff-4"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install tiff"
        ]
      }
    }
  }
}
