{
  "schema_version": "2026-07-01",
  "name": "libopenjp2/libopenjp2",
  "version": "2.5.2",
  "description": "PHP FFI wrapper for OpenJPEG JPEG 2000 encoding and decoding.",
  "authors": [
    {
      "name": "OpenJPEG maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libopenjp2\\Libopenjp2",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-threading.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libopenjp2": {
      "symbol_prefix": "opj",
      "library_names": [
        "libopenjp2.dylib",
        "libopenjp2.so",
        "openjp2.dll"
      ],
      "header_names": [
        "openjpeg.h"
      ],
      "version": ">=2.3.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install openjpeg"
        ],
        "check_if_exists": [
          "brew list openjpeg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libopenjp2-7-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libopenjp2"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libopenjp2-7-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libopenjp2"
        ]
      },
      "alpine": {
        "commands": [
          "apk add openjpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libopenjp2"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y openjpeg2-devel"
        ],
        "check_if_exists": [
          "rpm -q openjpeg2-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y openjpeg2-devel"
        ],
        "check_if_exists": [
          "rpm -q openjpeg2-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install openjpeg"
        ]
      }
    }
  }
}
