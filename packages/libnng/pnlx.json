{
  "schema_version": "2026-07-01",
  "name": "libnng/libnng",
  "version": "1.8.0",
  "description": "PHP FFI wrapper for nanomsg-next-gen (nng) scalable messaging.",
  "authors": [
    {
      "name": "NNG maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnng\\Libnng",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-utilities.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64",
      "libc": "glibc"
    },
    {
      "os": "linux",
      "arch": "aarch64",
      "libc": "glibc"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "nng": {
      "symbol_prefix": "nng",
      "library_names": [
        "libnng.dylib",
        "libnng.so",
        "nng.dll"
      ],
      "header_names": [
        "nng/nng.h"
      ],
      "version": ">=1.5.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install nng"
        ],
        "check_if_exists": [
          "brew list nng"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libnng-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nng"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libnng-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nng"
        ]
      },
      "alpine": {
        "commands": [
          "apk add nng-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nng"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y nng-devel"
        ],
        "check_if_exists": [
          "rpm -q nng-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y nng-devel"
        ],
        "check_if_exists": [
          "rpm -q nng-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install nng"
        ]
      }
    }
  }
}
