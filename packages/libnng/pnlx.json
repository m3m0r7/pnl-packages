{
  "schema_version": "2026-07-01",
  "name": "libnng/libnng",
  "version": "1.8.0",
  "description": "PHP FFI wrapper for nanomsg-next-gen (nng) scalable messaging.",
  "authors": [
    {
      "name": "NNG maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnng\\Libnng",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install nng"
      ],
      "checkIfExists": [
        "brew list nng"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libnng-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists nng"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libnng-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists nng"
      ]
    },
    "alpine": {
      "install": [
        "apk add nng-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists nng"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y nng-devel"
      ],
      "checkIfExists": [
        "rpm -q nng-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y nng-devel"
      ],
      "checkIfExists": [
        "rpm -q nng-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install nng"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "nng": {
      "symbol_prefix": "nng",
      "library_names": [
        "libnng.dylib",
        "libnng.so",
        "nng.dll"
      ],
      "header_names": [
        "nng/nng.h"
      ],
      "version": ">=1.5.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
