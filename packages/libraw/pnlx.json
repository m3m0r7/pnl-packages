{
  "schema_version": "2026-07-01",
  "name": "libraw/libraw",
  "version": "0.21.2",
  "description": "PHP FFI wrapper for LibRaw camera raw image decoding.",
  "authors": [
    {
      "name": "LibRaw maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libraw\\Libraw",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libraw": {
      "symbol_prefix": "libraw",
      "library_names": [
        "libraw.dylib",
        "libraw.so",
        "raw.dll"
      ],
      "header_names": [
        "libraw/libraw.h"
      ],
      "version": ">=0.20.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libraw"
        ],
        "check_if_exists": [
          "brew list libraw"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libraw-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libraw"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libraw-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libraw"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libraw-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libraw"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y LibRaw-devel"
        ],
        "check_if_exists": [
          "rpm -q LibRaw-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y LibRaw-devel"
        ],
        "check_if_exists": [
          "rpm -q LibRaw-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libraw"
        ]
      }
    }
  }
}
