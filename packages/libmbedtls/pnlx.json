{
  "schema_version": "2026-07-01",
  "name": "libmbedtls/libmbedtls",
  "version": "3.6.0",
  "description": "PHP FFI wrapper for Mbed TLS.",
  "authors": [
    {
      "name": "Mbed TLS maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmbedtls\\Libmbedtls",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-ciphersuite-keysize.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmbedtls": {
      "symbol_prefix": "mbedtls",
      "library_names": [
        "libmbedtls.dylib",
        "libmbedtls.so",
        "mbedtls.dll"
      ],
      "header_names": [
        "mbedtls/ssl.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mbedtls"
        ],
        "check_if_exists": [
          "brew list mbedtls"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmbedtls-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists mbedtls"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmbedtls-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists mbedtls"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mbedtls-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists mbedtls"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mbedtls-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists mbedtls"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y mbedtls-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists mbedtls"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install mbedtls"
        ]
      }
    }
  }
}
