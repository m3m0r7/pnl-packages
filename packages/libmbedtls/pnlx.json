{
  "schema_version": "2026-07-01",
  "name": "libmbedtls/libmbedtls",
  "version": "3.6.0",
  "description": "PHP FFI wrapper for Mbed TLS.",
  "authors": [
    {
      "name": "Mbed TLS maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmbedtls\\Libmbedtls",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install mbedtls"
      ],
      "checkIfExists": [
        "brew list mbedtls"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmbedtls-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists mbedtls"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmbedtls-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists mbedtls"
      ]
    },
    "alpine": {
      "install": [
        "apk add mbedtls-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists mbedtls"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y mbedtls-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists mbedtls"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y mbedtls-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists mbedtls"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install mbedtls"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmbedtls": {
      "symbol_prefix": "mbedtls",
      "library_names": [
        "libmbedtls.dylib",
        "libmbedtls.so",
        "mbedtls.dll"
      ],
      "header_names": [
        "mbedtls/ssl.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
