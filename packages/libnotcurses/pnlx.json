{
  "schema_version": "2026-07-01",
  "name": "libnotcurses/libnotcurses",
  "version": "3.0.9",
  "description": "PHP FFI wrapper for notcurses rich TUI / terminal graphics.",
  "authors": [
    {
      "name": "notcurses maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnotcurses\\Libnotcurses",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-blitters.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "notcurses": {
      "symbol_prefix": "notcurses",
      "library_names": [
        "libnotcurses-core.dylib",
        "libnotcurses-core.so",
        "libnotcurses.dylib",
        "libnotcurses.so"
      ],
      "header_names": [
        "notcurses/notcurses.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install notcurses"
        ],
        "check_if_exists": [
          "brew list notcurses"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libnotcurses-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists notcurses"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libnotcurses-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists notcurses"
        ]
      },
      "alpine": {
        "commands": [
          "apk add notcurses-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists notcurses"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y notcurses-devel"
        ],
        "check_if_exists": [
          "rpm -q notcurses-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y notcurses-devel"
        ],
        "check_if_exists": [
          "rpm -q notcurses-devel"
        ]
      }
    }
  }
}
