{
  "schema_version": "2026-07-01",
  "name": "libcjson/libcjson",
  "version": "1.7.18",
  "description": "PHP FFI wrapper for cJSON JSON parsing.",
  "authors": [
    {
      "name": "cJSON maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcjson\\Libcjson",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install cjson"
      ],
      "checkIfExists": [
        "brew list cjson"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libcjson-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libcjson"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libcjson-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libcjson"
      ]
    },
    "alpine": {
      "install": [
        "apk add cjson-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libcjson"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y cjson-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libcjson"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y cjson-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libcjson"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install cjson"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "cjson": {
      "symbol_prefix": "cJSON",
      "library_names": [
        "libcjson.dylib",
        "libcjson.so",
        "cjson.dll"
      ],
      "header_names": [
        "cjson/cJSON.h"
      ],
      "version": ">=1.7.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
