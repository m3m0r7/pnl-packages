{
  "schema_version": "2026-07-01",
  "name": "libcjson/libcjson",
  "version": "1.7.18",
  "description": "PHP FFI wrapper for cJSON JSON parsing.",
  "authors": [
    {
      "name": "cJSON maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcjson\\Libcjson",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-build.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "cjson": {
      "symbol_prefix": "cJSON",
      "library_names": [
        "libcjson.dylib",
        "libcjson.so",
        "cjson.dll"
      ],
      "header_names": [
        "cjson/cJSON.h"
      ],
      "version": ">=1.7.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install cjson"
        ],
        "check_if_exists": [
          "brew list cjson"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcjson-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcjson"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcjson-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcjson"
        ]
      },
      "alpine": {
        "commands": [
          "apk add cjson-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcjson"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y cjson-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libcjson"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y cjson-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libcjson"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install cjson"
        ]
      }
    }
  }
}
