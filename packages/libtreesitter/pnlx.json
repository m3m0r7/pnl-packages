{
  "schema_version": "2026-07-01",
  "name": "libtreesitter/libtreesitter",
  "version": "0.22.6",
  "description": "PHP FFI wrapper for the Tree-sitter parsing library.",
  "authors": [
    {
      "name": "Tree-sitter maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtreesitter\\Libtreesitter",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-query-cursor.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libtree-sitter": {
      "symbol_prefix": "ts",
      "library_names": [
        "libtree-sitter.dylib",
        "libtree-sitter.so",
        "tree-sitter.dll"
      ],
      "header_names": [
        "tree_sitter/api.h"
      ],
      "version": ">=0.20.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install tree-sitter"
        ],
        "check_if_exists": [
          "brew list tree-sitter"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtree-sitter-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists tree-sitter"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtree-sitter-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists tree-sitter"
        ]
      },
      "alpine": {
        "commands": [
          "apk add tree-sitter-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists tree-sitter"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libtree-sitter-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists tree-sitter"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libtree-sitter-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists tree-sitter"
        ]
      }
    }
  }
}
