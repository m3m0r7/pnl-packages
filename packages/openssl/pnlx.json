{
  "schema_version": "2026-07-01",
  "name": "openssl/openssl",
  "version": "3.3.0",
  "description": "PHP FFI wrapper for OpenSSL libssl/libcrypto.",
  "authors": [
    {
      "name": "OpenSSL maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Openssl\\Openssl",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-alerts.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libssl": {
      "library_names": [
        "libssl.dylib",
        "libssl.so",
        "libssl.dll"
      ],
      "header_names": [
        "openssl/ssl.h",
        "openssl/crypto.h",
        "openssl/evp.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install openssl@3"
        ],
        "check_if_exists": [
          "brew list openssl@3"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists openssl"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists openssl"
        ]
      },
      "alpine": {
        "commands": [
          "apk add openssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists openssl"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y openssl-devel"
        ],
        "check_if_exists": [
          "rpm -q openssl-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y openssl-devel"
        ],
        "check_if_exists": [
          "rpm -q openssl-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install openssl"
        ]
      }
    }
  }
}
