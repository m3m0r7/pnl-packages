{
  "schema_version": "2026-07-01",
  "name": "openssl/openssl",
  "version": "3.3.0",
  "description": "PHP FFI wrapper for OpenSSL libssl/libcrypto.",
  "authors": [
    {
      "name": "OpenSSL maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Openssl\\Openssl",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install openssl@3"
      ],
      "checkIfExists": [
        "brew list openssl@3"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libssl-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists openssl"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libssl-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists openssl"
      ]
    },
    "alpine": {
      "install": [
        "apk add openssl-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists openssl"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y openssl-devel"
      ],
      "checkIfExists": [
        "rpm -q openssl-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y openssl-devel"
      ],
      "checkIfExists": [
        "rpm -q openssl-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install openssl"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libssl": {
      "library_names": [
        "libssl.dylib",
        "libssl.so",
        "libssl.dll"
      ],
      "header_names": [
        "openssl/ssl.h",
        "openssl/crypto.h",
        "openssl/evp.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
