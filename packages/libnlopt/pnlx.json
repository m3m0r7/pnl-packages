{
  "schema_version": "2026-07-01",
  "name": "libnlopt/libnlopt",
  "version": "2.7.1",
  "description": "PHP FFI wrapper for the NLopt nonlinear-optimization library.",
  "authors": [
    {
      "name": "NLopt maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnlopt\\Libnlopt",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-algorithm-introspection.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64",
      "libc": "glibc"
    },
    {
      "os": "linux",
      "arch": "aarch64",
      "libc": "glibc"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "nlopt": {
      "symbol_prefix": "nlopt",
      "library_names": [
        "libnlopt.dylib",
        "libnlopt.so",
        "nlopt.dll"
      ],
      "header_names": [
        "nlopt.h"
      ],
      "version": ">=2.6.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install nlopt"
        ],
        "check_if_exists": [
          "brew list nlopt"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libnlopt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nlopt"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libnlopt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nlopt"
        ]
      },
      "alpine": {
        "commands": [
          "apk add nlopt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nlopt"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y nlopt-devel"
        ],
        "check_if_exists": [
          "rpm -q nlopt-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y nlopt-devel"
        ],
        "check_if_exists": [
          "rpm -q nlopt-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install nlopt"
        ]
      }
    }
  }
}
