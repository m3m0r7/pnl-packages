{
  "schema_version": "2026-07-01",
  "name": "librtlsdr/librtlsdr",
  "version": "2.0.1",
  "description": "PHP FFI wrapper for librtlsdr SDR control.",
  "authors": [
    {
      "name": "librtlsdr maintainers"
    }
  ],
  "license": "GPL-2.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Librtlsdr\\Librtlsdr",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-serial-lookup.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "librtlsdr": {
      "symbol_prefix": "rtlsdr",
      "library_names": [
        "librtlsdr.dylib",
        "librtlsdr.so",
        "rtlsdr.dll"
      ],
      "header_names": [
        "rtl-sdr.h"
      ],
      "version": ">=0.6.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install librtlsdr"
        ],
        "check_if_exists": [
          "brew list librtlsdr"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y librtlsdr-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q librtlsdr"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y librtlsdr-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q librtlsdr"
        ]
      },
      "alpine": {
        "commands": [
          "apk add librtlsdr-dev"
        ],
        "check_if_exists": [
          "apk info -e rtl-sdr-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y rtl-sdr-devel"
        ],
        "check_if_exists": [
          "rpm -q rtl-sdr-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y rtl-sdr-devel"
        ],
        "check_if_exists": [
          "rpm -q rtl-sdr-devel"
        ]
      }
    }
  }
}
