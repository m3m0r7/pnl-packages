{
  "schema_version": "2026-07-01",
  "name": "librtlsdr/librtlsdr",
  "version": "2.0.1",
  "description": "PHP FFI wrapper for librtlsdr SDR control.",
  "authors": [
    {
      "name": "librtlsdr maintainers"
    }
  ],
  "license": "GPL-2.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Librtlsdr\\Librtlsdr",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install librtlsdr"
      ],
      "checkIfExists": [
        "brew list librtlsdr"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y librtlsdr-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q librtlsdr"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y librtlsdr-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q librtlsdr"
      ]
    },
    "alpine": {
      "install": [
        "apk add librtlsdr-dev"
      ],
      "checkIfExists": [
        "apk info -e rtl-sdr-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y rtl-sdr-devel"
      ],
      "checkIfExists": [
        "rpm -q rtl-sdr-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y rtl-sdr-devel"
      ],
      "checkIfExists": [
        "rpm -q rtl-sdr-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "librtlsdr": {
      "symbol_prefix": "rtlsdr",
      "library_names": [
        "librtlsdr.dylib",
        "librtlsdr.so",
        "rtlsdr.dll"
      ],
      "header_names": [
        "rtl-sdr.h"
      ],
      "version": ">=0.6.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
