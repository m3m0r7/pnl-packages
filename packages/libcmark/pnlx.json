{
  "schema_version": "2026-07-01",
  "name": "libcmark/libcmark",
  "version": "0.31.0",
  "description": "PHP FFI wrapper for the cmark CommonMark parser.",
  "authors": [
    {
      "name": "cmark maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcmark\\Libcmark",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libcmark": {
      "symbol_prefix": "cmark",
      "library_names": [
        "libcmark.dylib",
        "libcmark.so",
        "cmark.dll"
      ],
      "header_names": [
        "cmark.h"
      ],
      "version": ">=0.29.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install cmark"
        ],
        "check_if_exists": [
          "brew list cmark"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcmark-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libcmark"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcmark-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libcmark"
        ]
      },
      "alpine": {
        "commands": [
          "apk add cmark-dev"
        ],
        "check_if_exists": [
          "apk info -e cmark-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y cmark-devel"
        ],
        "check_if_exists": [
          "rpm -q cmark-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y cmark-devel"
        ],
        "check_if_exists": [
          "rpm -q cmark-devel"
        ]
      }
    }
  }
}
