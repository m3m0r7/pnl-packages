{
  "schema_version": "2026-07-01",
  "name": "libicu/libicu",
  "version": "74.2",
  "description": "PHP FFI wrapper for ICU Unicode utilities.",
  "authors": [
    {
      "name": "ICU maintainers"
    }
  ],
  "license": "ICU",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libicu\\Libicu",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-data-directory.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libicuuc": {
      "library_names": [
        "libicuuc.dylib",
        "libicuuc.so",
        "icuuc.dll"
      ],
      "header_names": [
        "unicode/utypes.h",
        "unicode/ustring.h"
      ],
      "version": ">=70.0.0 & <80.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install icu4c"
        ],
        "check_if_exists": [
          "brew list icu4c"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libicu-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists icu-uc"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libicu-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists icu-uc"
        ]
      },
      "alpine": {
        "commands": [
          "apk add icu-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists icu-uc"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libicu-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists icu-uc"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libicu-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists icu-uc"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install icu"
        ]
      }
    }
  }
}
