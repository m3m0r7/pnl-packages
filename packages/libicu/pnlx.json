{
  "schema_version": "2026-07-01",
  "name": "libicu/libicu",
  "version": "74.2",
  "description": "PHP FFI wrapper for ICU Unicode utilities.",
  "authors": [
    {
      "name": "ICU maintainers"
    }
  ],
  "license": "ICU",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libicu\\Libicu",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install icu4c"
      ],
      "checkIfExists": [
        "brew list icu4c"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libicu-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists icu-uc"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libicu-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists icu-uc"
      ]
    },
    "alpine": {
      "install": [
        "apk add icu-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists icu-uc"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libicu-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists icu-uc"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libicu-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists icu-uc"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install icu"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libicuuc": {
      "library_names": [
        "libicuuc.dylib",
        "libicuuc.so",
        "icuuc.dll"
      ],
      "header_names": [
        "unicode/utypes.h",
        "unicode/ustring.h"
      ],
      "version": ">=70.0.0 & <80.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
