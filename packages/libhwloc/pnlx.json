{
  "schema_version": "2026-07-01",
  "name": "libhwloc/libhwloc",
  "version": "2.12.0",
  "description": "PHP FFI wrapper for hwloc, the Portable Hardware Locality library.",
  "authors": [
    {
      "name": "Libhwloc maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libhwloc\\Libhwloc",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-object-types.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "hwloc": {
      "symbol_prefix": "hwloc",
      "library_names": [
        "libhwloc.dylib",
        "libhwloc.so",
        "hwloc.dll"
      ],
      "header_names": [
        "hwloc.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install hwloc"
        ],
        "check_if_exists": [
          "brew list hwloc"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libhwloc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hwloc"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libhwloc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hwloc"
        ]
      },
      "alpine": {
        "commands": [
          "apk add hwloc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hwloc"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y hwloc-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists hwloc"
        ]
      }
    }
  }
}
