{
  "schema_version": "2026-07-01",
  "name": "libexpat/libexpat",
  "version": "2.6.2",
  "description": "PHP FFI wrapper for the Expat XML parser.",
  "authors": [
    {
      "name": "Expat maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libexpat\\Libexpat",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install expat"
      ],
      "checkIfExists": [
        "brew list expat"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libexpat1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists expat"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libexpat1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists expat"
      ]
    },
    "alpine": {
      "install": [
        "apk add expat-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists expat"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y expat-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists expat"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y expat-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists expat"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install expat"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libexpat": {
      "symbol_prefix": "XML",
      "library_names": [
        "libexpat.dylib",
        "libexpat.so",
        "expat.dll"
      ],
      "header_names": [
        "expat.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
