{
  "schema_version": "2026-07-01",
  "name": "libexpat/libexpat",
  "version": "2.6.2",
  "description": "PHP FFI wrapper for the Expat XML parser.",
  "authors": [
    {
      "name": "Expat maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libexpat\\Libexpat",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libexpat": {
      "symbol_prefix": "XML",
      "library_names": [
        "libexpat.dylib",
        "libexpat.so",
        "expat.dll"
      ],
      "header_names": [
        "expat.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install expat"
        ],
        "check_if_exists": [
          "brew list expat"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libexpat1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists expat"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libexpat1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists expat"
        ]
      },
      "alpine": {
        "commands": [
          "apk add expat-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists expat"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y expat-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists expat"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y expat-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists expat"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install expat"
        ]
      }
    }
  }
}
