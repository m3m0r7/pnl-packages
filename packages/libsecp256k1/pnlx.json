{
  "schema_version": "2026-07-01",
  "name": "libsecp256k1/libsecp256k1",
  "version": "0.5.1",
  "description": "PHP FFI wrapper for libsecp256k1 elliptic-curve cryptography.",
  "authors": [
    {
      "name": "Bitcoin Core / libsecp256k1 maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsecp256k1\\Libsecp256k1",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-selftest.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "secp256k1": {
      "symbol_prefix": "secp256k1",
      "library_names": [
        "libsecp256k1.dylib",
        "libsecp256k1.so",
        "secp256k1.dll"
      ],
      "header_names": [
        "secp256k1.h"
      ],
      "version": ">=0.3.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install secp256k1"
        ],
        "check_if_exists": [
          "brew list secp256k1"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsecp256k1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsecp256k1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsecp256k1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsecp256k1"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libsecp256k1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsecp256k1"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libsecp256k1-devel"
        ],
        "check_if_exists": [
          "rpm -q libsecp256k1-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libsecp256k1-devel"
        ],
        "check_if_exists": [
          "rpm -q libsecp256k1-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install secp256k1"
        ]
      }
    }
  }
}
