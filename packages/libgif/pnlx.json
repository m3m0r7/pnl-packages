{
  "schema_version": "2026-07-01",
  "name": "libgif/libgif",
  "version": "5.2.2",
  "description": "PHP FFI wrapper for giflib GIF codec.",
  "authors": [
    {
      "name": "giflib maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgif\\Libgif",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libgif": {
      "library_names": [
        "libgif.dylib",
        "libgif.so",
        "gif.dll"
      ],
      "header_names": [
        "gif_lib.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install giflib"
        ],
        "check_if_exists": [
          "brew list giflib"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgif-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libgif.so"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgif-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libgif.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add giflib-dev"
        ],
        "check_if_exists": [
          "apk info -e giflib-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y giflib-devel"
        ],
        "check_if_exists": [
          "rpm -q giflib-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y giflib-devel"
        ],
        "check_if_exists": [
          "rpm -q giflib-devel"
        ]
      }
    }
  }
}
