{
  "schema_version": "2026-07-01",
  "name": "libmsgpack/libmsgpack",
  "version": "6.0.0",
  "description": "PHP FFI wrapper for the msgpack-c library.",
  "authors": [
    {
      "name": "msgpack-c maintainers"
    }
  ],
  "license": "BSL-1.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmsgpack\\Libmsgpack",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install msgpack"
      ],
      "checkIfExists": [
        "brew list msgpack"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmsgpack-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libmsgpackc"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmsgpack-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libmsgpackc"
      ]
    },
    "alpine": {
      "install": [
        "apk add msgpack-c-dev"
      ],
      "checkIfExists": [
        "apk info -e msgpack-c-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y msgpack-devel"
      ],
      "checkIfExists": [
        "rpm -q msgpack-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y msgpack-devel"
      ],
      "checkIfExists": [
        "rpm -q msgpack-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install msgpack"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmsgpackc": {
      "symbol_prefix": "msgpack",
      "library_names": [
        "libmsgpackc.dylib",
        "libmsgpackc.so",
        "msgpackc.dll",
        "libmsgpack-c.so"
      ],
      "header_names": [
        "msgpack.h"
      ],
      "version": ">=4.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
