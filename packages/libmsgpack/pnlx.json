{
  "schema_version": "2026-07-01",
  "name": "libmsgpack/libmsgpack",
  "version": "6.0.0",
  "description": "PHP FFI wrapper for the msgpack-c library.",
  "authors": [
    {
      "name": "msgpack-c maintainers"
    }
  ],
  "license": "BSL-1.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmsgpack\\Libmsgpack",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmsgpackc": {
      "symbol_prefix": "msgpack",
      "library_names": [
        "libmsgpackc.dylib",
        "libmsgpackc.so",
        "msgpackc.dll",
        "libmsgpack-c.so"
      ],
      "header_names": [
        "msgpack.h"
      ],
      "version": ">=4.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install msgpack"
        ],
        "check_if_exists": [
          "brew list msgpack"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmsgpack-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libmsgpackc"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmsgpack-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libmsgpackc"
        ]
      },
      "alpine": {
        "commands": [
          "apk add msgpack-c-dev"
        ],
        "check_if_exists": [
          "apk info -e msgpack-c-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y msgpack-devel"
        ],
        "check_if_exists": [
          "rpm -q msgpack-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y msgpack-devel"
        ],
        "check_if_exists": [
          "rpm -q msgpack-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install msgpack"
        ]
      }
    }
  }
}
