{
  "schema_version": "2026-07-01",
  "name": "libgsl/libgsl",
  "version": "2.7.1",
  "description": "PHP FFI wrapper for the GNU Scientific Library.",
  "authors": [
    {
      "name": "GSL maintainers"
    }
  ],
  "license": "GPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgsl\\Libgsl",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-elementary-math.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libgsl": {
      "symbol_prefix": "gsl",
      "library_names": [
        "libgsl.dylib",
        "libgsl.so",
        "gsl.dll"
      ],
      "header_names": [
        "gsl/gsl_math.h",
        "gsl/gsl_vector.h",
        "gsl/gsl_blas.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {
    "*": [
      {
        "library_names": [
          "libgslcblas.dylib",
          "libgslcblas.so",
          "gslcblas.dll"
        ]
      }
    ]
  },
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install gsl"
        ],
        "check_if_exists": [
          "brew list gsl"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgsl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gsl"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgsl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gsl"
        ]
      },
      "alpine": {
        "commands": [
          "apk add gsl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gsl"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y gsl-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists gsl"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y gsl-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists gsl"
        ]
      }
    }
  }
}
