{
  "schema_version": "2026-07-01",
  "name": "libcapstone/libcapstone",
  "version": "5.0.6",
  "description": "PHP FFI wrapper for Capstone, the multi-architecture disassembly framework.",
  "authors": [
    {
      "name": "Libcapstone maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcapstone\\Libcapstone",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-support.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "capstone": {
      "symbol_prefix": "cs",
      "library_names": [
        "libcapstone.dylib",
        "libcapstone.so",
        "capstone.dll"
      ],
      "header_names": [
        "capstone/capstone.h"
      ],
      "version": ">=4.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install capstone"
        ],
        "check_if_exists": [
          "brew list capstone"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcapstone-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists capstone"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcapstone-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists capstone"
        ]
      },
      "alpine": {
        "commands": [
          "apk add capstone-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists capstone"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y capstone-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists capstone"
        ]
      }
    }
  }
}
