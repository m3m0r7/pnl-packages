{
  "schema_version": "2026-07-01",
  "name": "libmaxminddb/libmaxminddb",
  "version": "1.10.0",
  "description": "PHP FFI wrapper for libmaxminddb MaxMind DB (GeoIP2) lookups.",
  "authors": [
    {
      "name": "MaxMind maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmaxminddb\\Libmaxminddb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strerror.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmaxminddb": {
      "symbol_prefix": "MMDB",
      "library_names": [
        "libmaxminddb.dylib",
        "libmaxminddb.so",
        "maxminddb.dll"
      ],
      "header_names": [
        "maxminddb.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libmaxminddb"
        ],
        "check_if_exists": [
          "brew list libmaxminddb"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmaxminddb-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmaxminddb"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmaxminddb-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmaxminddb"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libmaxminddb-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmaxminddb"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libmaxminddb-devel"
        ],
        "check_if_exists": [
          "rpm -q libmaxminddb-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libmaxminddb-devel"
        ],
        "check_if_exists": [
          "rpm -q libmaxminddb-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libmaxminddb"
        ]
      }
    }
  }
}
