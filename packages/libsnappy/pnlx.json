{
  "schema_version": "2026-07-01",
  "name": "libsnappy/libsnappy",
  "version": "1.2.1",
  "description": "PHP FFI wrapper for the Snappy compression C API.",
  "authors": [
    {
      "name": "Snappy maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsnappy\\Libsnappy",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-validate.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "snappy": {
      "symbol_prefix": "snappy",
      "library_names": [
        "libsnappy.dylib",
        "libsnappy.so",
        "snappy.dll"
      ],
      "header_names": [
        "snappy-c.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install snappy"
        ],
        "check_if_exists": [
          "brew list snappy"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsnappy-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libsnappy"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsnappy-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libsnappy"
        ]
      },
      "alpine": {
        "commands": [
          "apk add snappy-dev"
        ],
        "check_if_exists": [
          "apk info -e snappy-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y snappy-devel"
        ],
        "check_if_exists": [
          "rpm -q snappy-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y snappy-devel"
        ],
        "check_if_exists": [
          "rpm -q snappy-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install snappy"
        ]
      }
    }
  }
}
