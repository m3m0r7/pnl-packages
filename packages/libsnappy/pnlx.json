{
  "schema_version": "2026-07-01",
  "name": "libsnappy/libsnappy",
  "version": "1.2.1",
  "description": "PHP FFI wrapper for the Snappy compression C API.",
  "authors": [
    {
      "name": "Snappy maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsnappy\\Libsnappy",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install snappy"
      ],
      "checkIfExists": [
        "brew list snappy"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libsnappy-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libsnappy"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libsnappy-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libsnappy"
      ]
    },
    "alpine": {
      "install": [
        "apk add snappy-dev"
      ],
      "checkIfExists": [
        "apk info -e snappy-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y snappy-devel"
      ],
      "checkIfExists": [
        "rpm -q snappy-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y snappy-devel"
      ],
      "checkIfExists": [
        "rpm -q snappy-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install snappy"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "snappy": {
      "symbol_prefix": "snappy",
      "library_names": [
        "libsnappy.dylib",
        "libsnappy.so",
        "snappy.dll"
      ],
      "header_names": [
        "snappy-c.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
