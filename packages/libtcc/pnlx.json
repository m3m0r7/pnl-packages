{
  "schema_version": "2026-07-01",
  "name": "libtcc/libtcc",
  "version": "0.9.27",
  "description": "PHP FFI wrapper for the TinyCC compiler.",
  "authors": [
    {
      "name": "TinyCC maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtcc\\Libtcc",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install tinycc"
      ],
      "checkIfExists": [
        "brew list tinycc"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libtcc-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libtcc.so"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libtcc-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libtcc.so"
      ]
    },
    "alpine": {
      "install": [
        "apk add tcc"
      ],
      "checkIfExists": [
        "apk info -e tcc"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y tcc"
      ],
      "checkIfExists": [
        "rpm -q tcc"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y tcc"
      ],
      "checkIfExists": [
        "rpm -q tcc"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libtcc": {
      "symbol_prefix": "tcc",
      "library_names": [
        "libtcc.dylib",
        "libtcc.so",
        "tcc.dll"
      ],
      "header_names": [
        "libtcc.h"
      ],
      "version": ">=0.9.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
