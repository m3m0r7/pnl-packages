{
  "schema_version": "2026-07-01",
  "name": "libtcc/libtcc",
  "version": "0.9.27",
  "description": "PHP FFI wrapper for the TinyCC compiler.",
  "authors": [
    {
      "name": "TinyCC maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtcc\\Libtcc",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libtcc": {
      "symbol_prefix": "tcc",
      "library_names": [
        "libtcc.dylib",
        "libtcc.so",
        "tcc.dll"
      ],
      "header_names": [
        "libtcc.h"
      ],
      "version": ">=0.9.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install tinycc"
        ],
        "check_if_exists": [
          "brew list tinycc"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtcc-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libtcc.so"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtcc-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libtcc.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add tcc"
        ],
        "check_if_exists": [
          "apk info -e tcc"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y tcc"
        ],
        "check_if_exists": [
          "rpm -q tcc"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y tcc"
        ],
        "check_if_exists": [
          "rpm -q tcc"
        ]
      }
    }
  }
}
