{
  "schema_version": "2026-07-01",
  "name": "libutf8proc/libutf8proc",
  "version": "2.9.0",
  "description": "PHP FFI wrapper for the utf8proc Unicode library.",
  "authors": [
    {
      "name": "utf8proc maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libutf8proc\\Libutf8proc",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install utf8proc"
      ],
      "checkIfExists": [
        "brew list utf8proc"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libutf8proc-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libutf8proc"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libutf8proc-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libutf8proc"
      ]
    },
    "alpine": {
      "install": [
        "apk add utf8proc-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libutf8proc"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y utf8proc-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libutf8proc"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y utf8proc-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libutf8proc"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install utf8proc"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libutf8proc": {
      "symbol_prefix": "utf8proc",
      "library_names": [
        "libutf8proc.dylib",
        "libutf8proc.so",
        "utf8proc.dll"
      ],
      "header_names": [
        "utf8proc.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
