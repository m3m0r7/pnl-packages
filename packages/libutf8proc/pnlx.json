{
  "schema_version": "2026-07-01",
  "name": "libutf8proc/libutf8proc",
  "version": "2.9.0",
  "description": "PHP FFI wrapper for the utf8proc Unicode library.",
  "authors": [
    {
      "name": "utf8proc maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libutf8proc\\Libutf8proc",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-case-mapping.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libutf8proc": {
      "symbol_prefix": "utf8proc",
      "library_names": [
        "libutf8proc.dylib",
        "libutf8proc.so",
        "utf8proc.dll"
      ],
      "header_names": [
        "utf8proc.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install utf8proc"
        ],
        "check_if_exists": [
          "brew list utf8proc"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libutf8proc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libutf8proc"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libutf8proc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libutf8proc"
        ]
      },
      "alpine": {
        "commands": [
          "apk add utf8proc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libutf8proc"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y utf8proc-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libutf8proc"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y utf8proc-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libutf8proc"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install utf8proc"
        ]
      }
    }
  }
}
