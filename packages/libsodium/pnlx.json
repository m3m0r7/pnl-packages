{
  "schema_version": "2026-07-01",
  "name": "libsodium/libsodium",
  "version": "1.0.19",
  "description": "PHP FFI wrapper for libsodium cryptography.",
  "authors": [
    {
      "name": "libsodium maintainers"
    }
  ],
  "license": "ISC",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsodium\\Libsodium",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-random.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libsodium": {
      "library_names": [
        "libsodium.dylib",
        "libsodium.so",
        "libsodium.dll"
      ],
      "header_names": [
        "sodium.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libsodium"
        ],
        "check_if_exists": [
          "brew list libsodium"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsodium-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsodium"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsodium-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsodium"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libsodium-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsodium"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libsodium-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libsodium"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libsodium-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libsodium"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libsodium"
        ]
      }
    }
  }
}
