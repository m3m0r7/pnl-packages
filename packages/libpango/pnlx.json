{
  "schema_version": "2026-07-01",
  "name": "libpango/libpango",
  "version": "1.52.0",
  "description": "PHP FFI wrapper for Pango text layout and rendering.",
  "authors": [
    {
      "name": "GNOME / Pango maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpango\\Libpango",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-units.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "pango": {
      "symbol_prefix": "pango",
      "library_names": [
        "libpango-1.0.dylib",
        "libpango-1.0.so",
        "pango-1.0.dll"
      ],
      "header_names": [
        "pango/pango.h"
      ],
      "version": ">=1.40.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install pango"
        ],
        "check_if_exists": [
          "brew list pango"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpango1.0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists pango"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpango1.0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists pango"
        ]
      },
      "alpine": {
        "commands": [
          "apk add pango-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists pango"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y pango-devel"
        ],
        "check_if_exists": [
          "rpm -q pango-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y pango-devel"
        ],
        "check_if_exists": [
          "rpm -q pango-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install pango"
        ]
      }
    }
  }
}
