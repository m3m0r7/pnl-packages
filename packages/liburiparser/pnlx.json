{
  "schema_version": "2026-07-01",
  "name": "liburiparser/liburiparser",
  "version": "0.9.8",
  "description": "PHP FFI wrapper for the uriparser RFC 3986 URI parsing library.",
  "authors": [
    {
      "name": "uriparser maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Liburiparser\\Liburiparser",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "uriparser": {
      "symbol_prefix": "uri",
      "library_names": [
        "liburiparser.dylib",
        "liburiparser.so",
        "uriparser.dll"
      ],
      "header_names": [
        "uriparser/Uri.h"
      ],
      "version": ">=0.9.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install uriparser"
        ],
        "check_if_exists": [
          "brew list uriparser"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y liburiparser-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists liburiparser"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y liburiparser-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists liburiparser"
        ]
      },
      "alpine": {
        "commands": [
          "apk add uriparser-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists liburiparser"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y uriparser-devel"
        ],
        "check_if_exists": [
          "rpm -q uriparser-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y uriparser-devel"
        ],
        "check_if_exists": [
          "rpm -q uriparser-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install uriparser"
        ]
      }
    }
  }
}
