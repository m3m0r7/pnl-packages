{
  "schema_version": "2026-07-01",
  "name": "libopenblas/libopenblas",
  "version": "0.3.27",
  "description": "PHP FFI wrapper for the OpenBLAS/CBLAS interface.",
  "authors": [
    {
      "name": "OpenBLAS maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libopenblas\\Libopenblas",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-runtime-config.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libopenblas": {
      "symbol_prefix": "cblas",
      "library_names": [
        "libopenblas.dylib",
        "libopenblas.so",
        "openblas.dll"
      ],
      "header_names": [
        "cblas.h"
      ],
      "version": ">=0.3.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install openblas"
        ],
        "check_if_exists": [
          "brew list openblas"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libopenblas-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists openblas"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libopenblas-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists openblas"
        ]
      },
      "alpine": {
        "commands": [
          "apk add openblas-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists openblas"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y openblas-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists openblas"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y openblas-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists openblas"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install openblas"
        ]
      }
    }
  }
}
