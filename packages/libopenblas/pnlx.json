{
  "schema_version": "2026-07-01",
  "name": "libopenblas/libopenblas",
  "version": "0.3.27",
  "description": "PHP FFI wrapper for the OpenBLAS/CBLAS interface.",
  "authors": [
    {
      "name": "OpenBLAS maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libopenblas\\Libopenblas",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install openblas"
      ],
      "checkIfExists": [
        "brew list openblas"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libopenblas-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists openblas"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libopenblas-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists openblas"
      ]
    },
    "alpine": {
      "install": [
        "apk add openblas-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists openblas"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y openblas-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists openblas"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y openblas-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists openblas"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install openblas"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libopenblas": {
      "symbol_prefix": "cblas",
      "library_names": [
        "libopenblas.dylib",
        "libopenblas.so",
        "openblas.dll"
      ],
      "header_names": [
        "cblas.h"
      ],
      "version": ">=0.3.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
