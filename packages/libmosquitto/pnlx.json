{
  "schema_version": "2026-07-01",
  "name": "libmosquitto/libmosquitto",
  "version": "2.0.18",
  "description": "PHP FFI wrapper for the Mosquitto MQTT client.",
  "authors": [
    {
      "name": "Mosquitto maintainers"
    }
  ],
  "license": "EPL-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmosquitto\\Libmosquitto",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-error-strings.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmosquitto": {
      "symbol_prefix": "mosquitto",
      "library_names": [
        "libmosquitto.dylib",
        "libmosquitto.so",
        "mosquitto.dll"
      ],
      "header_names": [
        "mosquitto.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mosquitto"
        ],
        "check_if_exists": [
          "brew list mosquitto"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmosquitto-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmosquitto"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmosquitto-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmosquitto"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mosquitto-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmosquitto"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mosquitto-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmosquitto"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y mosquitto-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmosquitto"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install mosquitto"
        ]
      }
    }
  }
}
