{
  "schema_version": "2026-07-01",
  "name": "libgmp/libgmp",
  "version": "6.3.0",
  "description": "PHP FFI wrapper for the GNU Multiple Precision library.",
  "authors": [
    {
      "name": "GMP maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgmp\\Libgmp",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-float-precision.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "gmp": {
      "library_names": [
        "libgmp.dylib",
        "libgmp.so",
        "gmp.dll"
      ],
      "header_names": [
        "gmp.h"
      ],
      "version": ">=6.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install gmp"
        ],
        "check_if_exists": [
          "brew list gmp"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgmp-dev"
        ],
        "check_if_exists": [
          "dpkg -s libgmp-dev >/dev/null 2>&1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgmp-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libgmp.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add gmp-dev"
        ],
        "check_if_exists": [
          "apk info -e gmp-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y gmp-devel"
        ],
        "check_if_exists": [
          "rpm -q gmp-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y gmp-devel"
        ],
        "check_if_exists": [
          "rpm -q gmp-devel"
        ]
      }
    }
  }
}
