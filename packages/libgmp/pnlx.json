{
  "schema_version": "2026-07-01",
  "name": "libgmp/libgmp",
  "version": "6.3.0",
  "description": "PHP FFI wrapper for the GNU Multiple Precision library.",
  "authors": [
    {
      "name": "GMP maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgmp\\Libgmp",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install gmp"
      ],
      "checkIfExists": [
        "brew list gmp"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libgmp-dev"
      ],
      "checkIfExists": [
        "dpkg -s libgmp-dev >/dev/null 2>&1"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libgmp-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libgmp.so"
      ]
    },
    "alpine": {
      "install": [
        "apk add gmp-dev"
      ],
      "checkIfExists": [
        "apk info -e gmp-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y gmp-devel"
      ],
      "checkIfExists": [
        "rpm -q gmp-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y gmp-devel"
      ],
      "checkIfExists": [
        "rpm -q gmp-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "gmp": {
      "library_names": [
        "libgmp.dylib",
        "libgmp.so",
        "gmp.dll"
      ],
      "header_names": [
        "gmp.h"
      ],
      "version": ">=6.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
