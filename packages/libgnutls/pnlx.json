{
  "schema_version": "2026-07-01",
  "name": "libgnutls/libgnutls",
  "version": "3.8.5",
  "description": "PHP FFI wrapper for the GnuTLS transport-layer security library.",
  "authors": [
    {
      "name": "GnuTLS maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgnutls\\Libgnutls",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "gnutls": {
      "symbol_prefix": "gnutls",
      "library_names": [
        "libgnutls.dylib",
        "libgnutls.so"
      ],
      "header_names": [
        "gnutls/gnutls.h"
      ],
      "version": ">=3.6.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install gnutls"
        ],
        "check_if_exists": [
          "brew list gnutls"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgnutls28-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gnutls"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgnutls28-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gnutls"
        ]
      },
      "alpine": {
        "commands": [
          "apk add gnutls-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gnutls"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y gnutls-devel"
        ],
        "check_if_exists": [
          "rpm -q gnutls-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y gnutls-devel"
        ],
        "check_if_exists": [
          "rpm -q gnutls-devel"
        ]
      }
    }
  }
}
