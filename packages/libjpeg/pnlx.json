{
  "schema_version": "2026-07-01",
  "name": "libjpeg/libjpeg",
  "version": "3.0.2",
  "description": "PHP FFI wrapper for libjpeg image codec.",
  "authors": [
    {
      "name": "libjpeg-turbo maintainers"
    }
  ],
  "license": "IJG",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libjpeg\\Libjpeg",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libjpeg": {
      "symbol_prefix": "jpeg",
      "library_names": [
        "libjpeg.dylib",
        "libjpeg.so",
        "jpeg.dll"
      ],
      "header_names": [
        "jpeglib.h"
      ],
      "version": ">=8.0.0 & <10.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install jpeg-turbo"
        ],
        "check_if_exists": [
          "brew list jpeg-turbo"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libjpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libjpeg"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libjpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libjpeg"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libjpeg-turbo-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libjpeg"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libjpeg-turbo-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libjpeg"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libjpeg-turbo-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libjpeg"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libjpeg-turbo"
        ]
      }
    }
  }
}
