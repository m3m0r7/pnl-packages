{
  "schema_version": "2026-07-01",
  "name": "libvips/libvips",
  "version": "8.15.1",
  "description": "PHP FFI wrapper for the libvips demand-driven image processing library.",
  "authors": [
    {
      "name": "libvips maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libvips\\Libvips",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "vips": {
      "symbol_prefix": "vips",
      "library_names": [
        "libvips.dylib",
        "libvips.so"
      ],
      "header_names": [
        "vips/vips.h"
      ],
      "version": ">=8.10.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install vips"
        ],
        "check_if_exists": [
          "brew list vips"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libvips-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vips"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libvips-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vips"
        ]
      },
      "alpine": {
        "commands": [
          "apk add vips-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vips"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y vips-devel"
        ],
        "check_if_exists": [
          "rpm -q vips-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y vips-devel"
        ],
        "check_if_exists": [
          "rpm -q vips-devel"
        ]
      }
    }
  }
}
