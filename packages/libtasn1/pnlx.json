{
  "schema_version": "2026-07-01",
  "name": "libtasn1/libtasn1",
  "version": "4.20.0",
  "description": "PHP FFI wrapper for GNU Libtasn1, an ASN.1 / DER library.",
  "authors": [
    {
      "name": "Libtasn1 maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtasn1\\Libtasn1",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strerror.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "libtasn1": {
      "symbol_prefix": "asn1",
      "library_names": [
        "libtasn1.dylib",
        "libtasn1.so",
        "tasn1.dll"
      ],
      "header_names": [
        "libtasn1.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libtasn1"
        ],
        "check_if_exists": [
          "brew list libtasn1"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtasn1-6-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libtasn1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtasn1-6-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libtasn1"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libtasn1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libtasn1"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libtasn1-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libtasn1"
        ]
      }
    }
  }
}
