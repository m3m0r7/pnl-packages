{
  "schema_version": "2026-07-01",
  "name": "libbz2/libbz2",
  "version": "1.0.8",
  "description": "PHP FFI wrapper for bzip2 compression.",
  "authors": [
    {
      "name": "bzip2 maintainers"
    }
  ],
  "license": "bzip2-1.0.6",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libbz2\\Libbz2",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install bzip2"
      ],
      "checkIfExists": [
        "brew list bzip2"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libbz2-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libbz2"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libbz2-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libbz2"
      ]
    },
    "alpine": {
      "install": [
        "apk add bzip2-dev"
      ],
      "checkIfExists": [
        "apk info -e bzip2-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y bzip2-devel"
      ],
      "checkIfExists": [
        "rpm -q bzip2-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y bzip2-devel"
      ],
      "checkIfExists": [
        "rpm -q bzip2-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libbz2": {
      "symbol_prefix": "BZ2",
      "library_names": [
        "libbz2.dylib",
        "libbz2.so",
        "bz2.dll"
      ],
      "header_names": [
        "bzlib.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
