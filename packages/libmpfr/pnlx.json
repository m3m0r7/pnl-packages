{
  "schema_version": "2026-07-01",
  "name": "libmpfr/libmpfr",
  "version": "4.2.1",
  "description": "PHP FFI wrapper for the GNU MPFR library.",
  "authors": [
    {
      "name": "MPFR maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmpfr\\Libmpfr",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install mpfr"
      ],
      "checkIfExists": [
        "brew list mpfr"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmpfr-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libmpfr"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmpfr-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libmpfr"
      ]
    },
    "alpine": {
      "install": [
        "apk add mpfr-dev"
      ],
      "checkIfExists": [
        "apk info -e mpfr-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y mpfr-devel"
      ],
      "checkIfExists": [
        "rpm -q mpfr-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y mpfr-devel"
      ],
      "checkIfExists": [
        "rpm -q mpfr-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmpfr": {
      "symbol_prefix": "mpfr",
      "library_names": [
        "libmpfr.dylib",
        "libmpfr.so",
        "mpfr.dll"
      ],
      "header_names": [
        "mpfr.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
