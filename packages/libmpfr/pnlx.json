{
  "schema_version": "2026-07-01",
  "name": "libmpfr/libmpfr",
  "version": "4.2.1",
  "description": "PHP FFI wrapper for the GNU MPFR library.",
  "authors": [
    {
      "name": "MPFR maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmpfr\\Libmpfr",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-buildinfo.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmpfr": {
      "symbol_prefix": "mpfr",
      "library_names": [
        "libmpfr.dylib",
        "libmpfr.so",
        "mpfr.dll"
      ],
      "header_names": [
        "mpfr.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mpfr"
        ],
        "check_if_exists": [
          "brew list mpfr"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmpfr-dev"
        ],
        "check_if_exists": [
          "dpkg -s libmpfr-dev >/dev/null 2>&1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmpfr-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libmpfr"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mpfr-dev"
        ],
        "check_if_exists": [
          "apk info -e mpfr-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mpfr-devel"
        ],
        "check_if_exists": [
          "rpm -q mpfr-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y mpfr-devel"
        ],
        "check_if_exists": [
          "rpm -q mpfr-devel"
        ]
      }
    }
  }
}
