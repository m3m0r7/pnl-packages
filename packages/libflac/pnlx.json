{
  "schema_version": "2026-07-01",
  "name": "libflac/libflac",
  "version": "1.4.3",
  "description": "PHP FFI wrapper for the FLAC audio codec.",
  "authors": [
    {
      "name": "FLAC maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libflac\\Libflac",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-format.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libflac": {
      "symbol_prefix": "FLAC",
      "library_names": [
        "libFLAC.dylib",
        "libFLAC.so",
        "FLAC.dll"
      ],
      "header_names": [
        "FLAC/all.h"
      ],
      "version": ">=1.3.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install flac"
        ],
        "check_if_exists": [
          "brew list flac"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libflac-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists flac"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libflac-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists flac"
        ]
      },
      "alpine": {
        "commands": [
          "apk add flac-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists flac"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y flac-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists flac"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y flac-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists flac"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libflac"
        ]
      }
    }
  }
}
