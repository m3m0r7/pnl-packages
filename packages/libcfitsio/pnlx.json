{
  "schema_version": "2026-07-01",
  "name": "libcfitsio/libcfitsio",
  "version": "4.5.0",
  "description": "PHP FFI wrapper for CFITSIO, the FITS-file I/O library.",
  "authors": [
    {
      "name": "Libcfitsio maintainers"
    }
  ],
  "license": "cfitsio",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcfitsio\\Libcfitsio",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-timeout.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "cfitsio": {
      "symbol_prefix": "ff",
      "library_names": [
        "libcfitsio.dylib",
        "libcfitsio.so",
        "cfitsio.dll"
      ],
      "header_names": [
        "fitsio.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install cfitsio"
        ],
        "check_if_exists": [
          "brew list cfitsio"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcfitsio-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists cfitsio"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcfitsio-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists cfitsio"
        ]
      },
      "alpine": {
        "commands": [
          "apk add cfitsio-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists cfitsio"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y cfitsio-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists cfitsio"
        ]
      }
    }
  }
}
