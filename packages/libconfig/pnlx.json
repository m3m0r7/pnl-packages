{
  "schema_version": "2026-07-01",
  "name": "libconfig/libconfig",
  "version": "1.7.3",
  "description": "PHP FFI wrapper for libconfig structured configuration files.",
  "authors": [
    {
      "name": "libconfig maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libconfig\\Libconfig",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-options.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libconfig": {
      "symbol_prefix": "config",
      "library_names": [
        "libconfig.dylib",
        "libconfig.so",
        "libconfig.dll"
      ],
      "header_names": [
        "libconfig.h"
      ],
      "version": ">=1.5.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libconfig"
        ],
        "check_if_exists": [
          "brew list libconfig"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libconfig-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libconfig"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libconfig-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libconfig"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libconfig-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libconfig"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libconfig-devel"
        ],
        "check_if_exists": [
          "rpm -q libconfig-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libconfig-devel"
        ],
        "check_if_exists": [
          "rpm -q libconfig-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libconfig"
        ]
      }
    }
  }
}
