{
  "schema_version": "2026-07-01",
  "name": "libconfig/libconfig",
  "version": "1.7.3",
  "description": "PHP FFI wrapper for libconfig structured configuration files.",
  "authors": [
    {
      "name": "libconfig maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libconfig\\Libconfig",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libconfig"
      ],
      "checkIfExists": [
        "brew list libconfig"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libconfig-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libconfig"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libconfig-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libconfig"
      ]
    },
    "alpine": {
      "install": [
        "apk add libconfig-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libconfig"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libconfig-devel"
      ],
      "checkIfExists": [
        "rpm -q libconfig-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libconfig-devel"
      ],
      "checkIfExists": [
        "rpm -q libconfig-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libconfig"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libconfig": {
      "symbol_prefix": "config",
      "library_names": [
        "libconfig.dylib",
        "libconfig.so",
        "libconfig.dll"
      ],
      "header_names": [
        "libconfig.h"
      ],
      "version": ">=1.5.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
