{
  "schema_version": "2026-07-01",
  "name": "librav1e/librav1e",
  "version": "0.8.1",
  "description": "PHP FFI wrapper for rav1e, the fast and safe AV1 encoder.",
  "authors": [
    {
      "name": "Librav1e maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Librav1e\\Librav1e",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-status.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "rav1e": {
      "symbol_prefix": "rav1e",
      "library_names": [
        "librav1e.dylib",
        "librav1e.so",
        "rav1e.dll"
      ],
      "header_names": [
        "rav1e/rav1e.h"
      ],
      "version": ">=0.5.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install rav1e"
        ],
        "check_if_exists": [
          "brew list rav1e"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y librav1e-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists rav1e"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y librav1e-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists rav1e"
        ]
      },
      "alpine": {
        "commands": [
          "apk add rav1e-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists rav1e"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y rav1e-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists rav1e"
        ]
      }
    }
  }
}
