{
  "schema_version": "2026-07-01",
  "name": "libxml2/libxml2",
  "version": "2.12.6",
  "description": "PHP FFI wrapper for libxml2 XML parser.",
  "authors": [
    {
      "name": "libxml2 maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libxml2\\Libxml2",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strings.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libxml2": {
      "symbol_prefix": "xml",
      "library_names": [
        "libxml2.dylib",
        "libxml2.so",
        "libxml2.dll"
      ],
      "header_names": [
        "libxml/parser.h",
        "libxml/tree.h",
        "libxml2/libxml/parser.h",
        "libxml2/libxml/tree.h"
      ],
      "version": ">=2.9.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libxml2"
        ],
        "check_if_exists": [
          "brew list libxml2"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libxml2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxml-2.0"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libxml2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxml-2.0"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libxml2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxml-2.0"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libxml2-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libxml-2.0"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libxml2-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libxml-2.0"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libxml2"
        ]
      }
    }
  }
}
