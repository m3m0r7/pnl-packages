{
  "schema_version": "2026-07-01",
  "name": "libxml2/libxml2",
  "version": "2.12.6",
  "description": "PHP FFI wrapper for libxml2 XML parser.",
  "authors": [
    {
      "name": "libxml2 maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libxml2\\Libxml2",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libxml2"
      ],
      "checkIfExists": [
        "brew list libxml2"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libxml2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxml-2.0"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libxml2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxml-2.0"
      ]
    },
    "alpine": {
      "install": [
        "apk add libxml2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxml-2.0"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libxml2-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libxml-2.0"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libxml2-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libxml-2.0"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libxml2"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libxml2": {
      "symbol_prefix": "xml",
      "library_names": [
        "libxml2.dylib",
        "libxml2.so",
        "libxml2.dll"
      ],
      "header_names": [
        "libxml/parser.h",
        "libxml/tree.h"
      ],
      "version": ">=2.9.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
