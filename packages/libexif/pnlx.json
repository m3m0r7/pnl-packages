{
  "schema_version": "2026-07-01",
  "name": "libexif/libexif",
  "version": "0.6.24",
  "description": "PHP FFI wrapper for libexif EXIF metadata.",
  "authors": [
    {
      "name": "libexif maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libexif\\Libexif",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-tags.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libexif": {
      "symbol_prefix": "exif",
      "library_names": [
        "libexif.dylib",
        "libexif.so",
        "exif.dll"
      ],
      "header_names": [
        "libexif/exif-data.h"
      ],
      "version": ">=0.6.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libexif"
        ],
        "check_if_exists": [
          "brew list libexif"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libexif-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libexif"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libexif-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libexif"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libexif-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libexif"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libexif-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libexif"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libexif-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libexif"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libexif"
        ]
      }
    }
  }
}
