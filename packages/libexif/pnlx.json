{
  "schema_version": "2026-07-01",
  "name": "libexif/libexif",
  "version": "0.6.24",
  "description": "PHP FFI wrapper for libexif EXIF metadata.",
  "authors": [
    {
      "name": "libexif maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libexif\\Libexif",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libexif"
      ],
      "checkIfExists": [
        "brew list libexif"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libexif-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libexif"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libexif-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libexif"
      ]
    },
    "alpine": {
      "install": [
        "apk add libexif-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libexif"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libexif-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libexif"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libexif-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libexif"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libexif"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libexif": {
      "symbol_prefix": "exif",
      "library_names": [
        "libexif.dylib",
        "libexif.so",
        "exif.dll"
      ],
      "header_names": [
        "libexif/exif-data.h"
      ],
      "version": ">=0.6.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
