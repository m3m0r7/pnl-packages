{
  "schema_version": "2026-07-01",
  "name": "libfreetds/libfreetds",
  "version": "1.4.0",
  "description": "PHP FFI wrapper for FreeTDS DB-Library (Sybase/MSSQL).",
  "authors": [
    {
      "name": "Libfreetds maintainers"
    }
  ],
  "license": "LGPL-2.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libfreetds\\Libfreetds",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-types.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "sybdb": {
      "symbol_prefix": "db",
      "library_names": [
        "libsybdb.dylib",
        "libsybdb.so",
        "sybdb.dll"
      ],
      "header_names": [
        "sybdb.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install freetds"
        ],
        "check_if_exists": [
          "brew list freetds"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y freetds-dev"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y freetds-dev"
        ]
      },
      "alpine": {
        "commands": [
          "apk add freetds-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y freetds-devel"
        ]
      }
    }
  }
}
