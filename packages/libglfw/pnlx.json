{
  "schema_version": "2026-07-01",
  "name": "libglfw/libglfw",
  "version": "3.4.0",
  "description": "PHP FFI wrapper for the GLFW windowing library.",
  "authors": [
    {
      "name": "GLFW maintainers"
    }
  ],
  "license": "Zlib",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libglfw\\Libglfw",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-platforms.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "glfw3": {
      "symbol_prefix": "glfw",
      "library_names": [
        "libglfw.dylib",
        "libglfw.so",
        "glfw3.dll"
      ],
      "header_names": [
        "GLFW/glfw3.h"
      ],
      "version": ">=3.3.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install glfw"
        ],
        "check_if_exists": [
          "brew list glfw"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libglfw3-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists glfw3"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libglfw3-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists glfw3"
        ]
      },
      "alpine": {
        "commands": [
          "apk add glfw-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists glfw3"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y glfw-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists glfw3"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y glfw-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists glfw3"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install glfw3"
        ]
      }
    }
  }
}
