{
  "schema_version": "2026-07-01",
  "name": "libglfw/libglfw",
  "version": "3.4.0",
  "description": "PHP FFI wrapper for the GLFW windowing library.",
  "authors": [
    {
      "name": "GLFW maintainers"
    }
  ],
  "license": "Zlib",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libglfw\\Libglfw",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install glfw"
      ],
      "checkIfExists": [
        "brew list glfw"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libglfw3-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists glfw3"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libglfw3-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists glfw3"
      ]
    },
    "alpine": {
      "install": [
        "apk add glfw-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists glfw3"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y glfw-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists glfw3"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y glfw-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists glfw3"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install glfw3"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "glfw3": {
      "symbol_prefix": "glfw",
      "library_names": [
        "libglfw.dylib",
        "libglfw.so",
        "glfw3.dll"
      ],
      "header_names": [
        "GLFW/glfw3.h"
      ],
      "version": ">=3.3.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
