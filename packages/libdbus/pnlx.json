{
  "schema_version": "2026-07-01",
  "name": "libdbus/libdbus",
  "version": "1.14.10",
  "description": "PHP FFI wrapper for the D-Bus IPC library.",
  "authors": [
    {
      "name": "D-Bus maintainers"
    }
  ],
  "license": "AFL-2.1",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libdbus\\Libdbus",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install dbus"
      ],
      "checkIfExists": [
        "brew list dbus"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libdbus-1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists dbus-1"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libdbus-1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists dbus-1"
      ]
    },
    "alpine": {
      "install": [
        "apk add dbus-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists dbus-1"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y dbus-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists dbus-1"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y dbus-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists dbus-1"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libdbus-1": {
      "symbol_prefix": "dbus",
      "library_names": [
        "libdbus-1.dylib",
        "libdbus-1.so",
        "dbus-1.dll"
      ],
      "header_names": [
        "dbus/dbus.h"
      ],
      "version": ">=1.12.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
