{
  "schema_version": "2026-07-01",
  "name": "libdbus/libdbus",
  "version": "1.14.10",
  "description": "PHP FFI wrapper for the D-Bus IPC library.",
  "authors": [
    {
      "name": "D-Bus maintainers"
    }
  ],
  "license": "AFL-2.1",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libdbus\\Libdbus",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-message-types.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libdbus-1": {
      "symbol_prefix": "dbus",
      "library_names": [
        "libdbus-1.dylib",
        "libdbus-1.so",
        "dbus-1.dll"
      ],
      "header_names": [
        "dbus/dbus.h",
        "dbus-1.0/dbus/dbus.h"
      ],
      "version": ">=1.12.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install dbus"
        ],
        "check_if_exists": [
          "brew list dbus"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libdbus-1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists dbus-1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libdbus-1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists dbus-1"
        ]
      },
      "alpine": {
        "commands": [
          "apk add dbus-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists dbus-1"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y dbus-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists dbus-1"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y dbus-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists dbus-1"
        ]
      }
    }
  }
}
