{
  "schema_version": "2026-07-01",
  "name": "libmariadb/libmariadb",
  "version": "3.3.10",
  "description": "PHP FFI wrapper for the MariaDB/MySQL client library.",
  "authors": [
    {
      "name": "MariaDB Connector/C maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmariadb\\Libmariadb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-client.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmariadb": {
      "symbol_prefix": "mysql",
      "library_names": [
        "libmariadb.dylib",
        "libmariadb.so",
        "libmariadb.dll"
      ],
      "header_names": [
        "mysql.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mariadb-connector-c"
        ],
        "check_if_exists": [
          "brew list mariadb-connector-c"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmariadb-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmariadb"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmariadb-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmariadb"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mariadb-connector-c-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmariadb"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mariadb-connector-c-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmariadb"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y mariadb-connector-c-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmariadb"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libmariadb"
        ]
      }
    }
  }
}
