{
  "schema_version": "2026-07-01",
  "name": "libmariadb/libmariadb",
  "version": "3.3.10",
  "description": "PHP FFI wrapper for the MariaDB/MySQL client library.",
  "authors": [
    {
      "name": "MariaDB Connector/C maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmariadb\\Libmariadb",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install mariadb-connector-c"
      ],
      "checkIfExists": [
        "brew list mariadb-connector-c"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmariadb-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmariadb"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmariadb-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmariadb"
      ]
    },
    "alpine": {
      "install": [
        "apk add mariadb-connector-c-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmariadb"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y mariadb-connector-c-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libmariadb"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y mariadb-connector-c-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libmariadb"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libmariadb"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmariadb": {
      "symbol_prefix": "mysql",
      "library_names": [
        "libmariadb.dylib",
        "libmariadb.so",
        "libmariadb.dll"
      ],
      "header_names": [
        "mysql.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
