{
  "schema_version": "2026-07-01",
  "name": "libvpx/libvpx",
  "version": "1.14.1",
  "description": "PHP FFI wrapper for the libvpx VP8/VP9 video codec.",
  "authors": [
    {
      "name": "WebM / libvpx maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libvpx\\Libvpx",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-error-strings.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libvpx": {
      "symbol_prefix": "vpx",
      "library_names": [
        "libvpx.dylib",
        "libvpx.so",
        "vpx.dll"
      ],
      "header_names": [
        "vpx/vpx_codec.h",
        "vpx/vpx_encoder.h",
        "vpx/vpx_decoder.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libvpx"
        ],
        "check_if_exists": [
          "brew list libvpx"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libvpx-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vpx"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libvpx-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vpx"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libvpx-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vpx"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libvpx-devel"
        ],
        "check_if_exists": [
          "rpm -q libvpx-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libvpx-devel"
        ],
        "check_if_exists": [
          "rpm -q libvpx-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libvpx"
        ]
      }
    }
  }
}
