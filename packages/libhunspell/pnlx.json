{
  "schema_version": "2026-07-01",
  "name": "libhunspell/libhunspell",
  "version": "1.7.2",
  "description": "PHP FFI wrapper for the Hunspell spell checker.",
  "authors": [
    {
      "name": "Hunspell maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libhunspell\\Libhunspell",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-spellcheck.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "hunspell": {
      "symbol_prefix": "Hunspell",
      "library_names": [
        "libhunspell-1.7.dylib",
        "libhunspell-1.7.so",
        "hunspell.dll"
      ],
      "header_names": [
        "hunspell/hunspell.h"
      ],
      "version": ">=1.6.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install hunspell"
        ],
        "check_if_exists": [
          "brew list hunspell"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libhunspell-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hunspell"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libhunspell-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hunspell"
        ]
      },
      "alpine": {
        "commands": [
          "apk add hunspell-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hunspell"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y hunspell-devel"
        ],
        "check_if_exists": [
          "rpm -q hunspell-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y hunspell-devel"
        ],
        "check_if_exists": [
          "rpm -q hunspell-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install hunspell"
        ]
      }
    }
  }
}
