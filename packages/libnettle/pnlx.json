{
  "schema_version": "2026-07-01",
  "name": "libnettle/libnettle",
  "version": "3.9.1",
  "description": "PHP FFI wrapper for the Nettle cryptographic library.",
  "authors": [
    {
      "name": "Nettle maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnettle\\Libnettle",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install nettle"
      ],
      "checkIfExists": [
        "brew list nettle"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y nettle-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists nettle"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y nettle-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists nettle"
      ]
    },
    "alpine": {
      "install": [
        "apk add nettle-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists nettle"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y nettle-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists nettle"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y nettle-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists nettle"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install nettle"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libnettle": {
      "symbol_prefix": "nettle",
      "library_names": [
        "libnettle.dylib",
        "libnettle.so",
        "nettle.dll"
      ],
      "header_names": [
        "nettle/nettle-meta.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
