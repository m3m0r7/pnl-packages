{
  "schema_version": "2026-07-01",
  "name": "libnettle/libnettle",
  "version": "3.9.1",
  "description": "PHP FFI wrapper for the Nettle cryptographic library.",
  "authors": [
    {
      "name": "Nettle maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnettle\\Libnettle",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-cipher-registry.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libnettle": {
      "symbol_prefix": "nettle",
      "library_names": [
        "libnettle.dylib",
        "libnettle.so",
        "nettle.dll"
      ],
      "header_names": [
        "nettle/nettle-meta.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install nettle"
        ],
        "check_if_exists": [
          "brew list nettle"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y nettle-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nettle"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y nettle-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nettle"
        ]
      },
      "alpine": {
        "commands": [
          "apk add nettle-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists nettle"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y nettle-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists nettle"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y nettle-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists nettle"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install nettle"
        ]
      }
    }
  }
}
