{
  "schema_version": "2026-07-01",
  "name": "libswscale/libswscale",
  "version": "8.1.100",
  "description": "PHP FFI wrapper for FFmpeg libswscale.",
  "authors": [
    {
      "name": "FFmpeg libswscale maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libswscale\\Libswscale",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-format-support.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libswscale": {
      "symbol_prefix": "sws",
      "library_names": [
        "libswscale.dylib",
        "libswscale.so",
        "swscale.dll"
      ],
      "header_names": [
        "libswscale/swscale.h"
      ],
      "version": ">=5.0.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ffmpeg"
        ],
        "check_if_exists": [
          "brew list ffmpeg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libswscale-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libswscale"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libswscale-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libswscale"
        ]
      },
      "alpine": {
        "commands": [
          "apk add ffmpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libswscale"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libswscale"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libswscale"
        ]
      }
    }
  }
}
