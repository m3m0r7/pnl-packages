{
  "schema_version": "2026-07-01",
  "name": "libreadline/libreadline",
  "version": "8.2",
  "description": "PHP FFI wrapper for GNU Readline line editing.",
  "authors": [
    {
      "name": "GNU Readline maintainers"
    }
  ],
  "license": "GPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libreadline\\Libreadline",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-variables.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "readline": {
      "symbol_prefix": "rl",
      "library_names": [
        "libreadline.dylib",
        "libreadline.so",
        "readline.dll"
      ],
      "header_names": [
        "readline/readline.h",
        "readline/history.h"
      ],
      "version": ">=8.0.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install readline"
        ],
        "check_if_exists": [
          "brew list readline"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libreadline-dev"
        ],
        "check_if_exists": [
          "dpkg -s libreadline-dev >/dev/null 2>&1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libreadline-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libreadline"
        ]
      },
      "alpine": {
        "commands": [
          "apk add readline-dev"
        ],
        "check_if_exists": [
          "apk info -e readline-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y readline-devel"
        ],
        "check_if_exists": [
          "rpm -q readline-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y readline-devel"
        ],
        "check_if_exists": [
          "rpm -q readline-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install readline"
        ]
      }
    }
  }
}
