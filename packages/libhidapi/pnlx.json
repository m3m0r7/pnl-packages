{
  "schema_version": "2026-07-01",
  "name": "libhidapi/libhidapi",
  "version": "0.14.0",
  "description": "PHP FFI wrapper for the HIDAPI USB HID library.",
  "authors": [
    {
      "name": "HIDAPI maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libhidapi\\Libhidapi",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libhidapi": {
      "symbol_prefix": "hid",
      "library_names": [
        "libhidapi.dylib",
        "libhidapi.so",
        "hidapi.dll",
        "libhidapi-libusb.so",
        "libhidapi-hidraw.so"
      ],
      "header_names": [
        "hidapi/hidapi.h"
      ],
      "version": ">=0.10.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install hidapi"
        ],
        "check_if_exists": [
          "brew list hidapi"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libhidapi-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hidapi-libusb"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libhidapi-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hidapi-libusb"
        ]
      },
      "alpine": {
        "commands": [
          "apk add hidapi-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hidapi-libusb"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y hidapi-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists hidapi-libusb"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y hidapi-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists hidapi-libusb"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install hidapi"
        ]
      }
    }
  }
}
