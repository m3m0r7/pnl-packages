{
  "schema_version": "2026-07-01",
  "name": "libhidapi/libhidapi",
  "version": "0.14.0",
  "description": "PHP FFI wrapper for the HIDAPI USB HID library.",
  "authors": [
    {
      "name": "HIDAPI maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libhidapi\\Libhidapi",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install hidapi"
      ],
      "checkIfExists": [
        "brew list hidapi"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libhidapi-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists hidapi-libusb"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libhidapi-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists hidapi-libusb"
      ]
    },
    "alpine": {
      "install": [
        "apk add hidapi-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists hidapi-libusb"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y hidapi-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists hidapi-libusb"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y hidapi-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists hidapi-libusb"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install hidapi"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libhidapi": {
      "symbol_prefix": "hid",
      "library_names": [
        "libhidapi.dylib",
        "libhidapi.so",
        "hidapi.dll",
        "libhidapi-libusb.so",
        "libhidapi-hidraw.so"
      ],
      "header_names": [
        "hidapi/hidapi.h"
      ],
      "version": ">=0.10.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
