{
  "schema_version": "2026-07-01",
  "name": "libassimp/libassimp",
  "version": "5.4.0",
  "description": "PHP FFI wrapper for Assimp 3D model import via its C API.",
  "authors": [
    {
      "name": "Open Asset Import Library maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libassimp\\Libassimp",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-texture-types.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "assimp": {
      "symbol_prefix": "ai",
      "library_names": [
        "libassimp.dylib",
        "libassimp.so",
        "assimp.dll"
      ],
      "header_names": [
        "assimp/cimport.h",
        "assimp/scene.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install assimp"
        ],
        "check_if_exists": [
          "brew list assimp"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libassimp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists assimp"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libassimp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists assimp"
        ]
      },
      "alpine": {
        "commands": [
          "apk add assimp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists assimp"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y assimp-devel"
        ],
        "check_if_exists": [
          "rpm -q assimp-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y assimp-devel"
        ],
        "check_if_exists": [
          "rpm -q assimp-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install assimp"
        ]
      }
    }
  }
}
