{
  "schema_version": "2026-07-01",
  "name": "libidn2/libidn2",
  "version": "2.3.7",
  "description": "PHP FFI wrapper for libidn2 IDNA handling.",
  "authors": [
    {
      "name": "libidn2 maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libidn2\\Libidn2",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-error-codes.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libidn2": {
      "symbol_prefix": "idn2",
      "library_names": [
        "libidn2.dylib",
        "libidn2.so",
        "idn2.dll"
      ],
      "header_names": [
        "idn2.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libidn2"
        ],
        "check_if_exists": [
          "brew list libidn2"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libidn2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libidn2"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libidn2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libidn2"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libidn2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libidn2"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libidn2-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libidn2"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libidn2-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libidn2"
        ]
      }
    }
  }
}
