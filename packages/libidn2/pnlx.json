{
  "schema_version": "2026-07-01",
  "name": "libidn2/libidn2",
  "version": "2.3.7",
  "description": "PHP FFI wrapper for libidn2 IDNA handling.",
  "authors": [
    {
      "name": "libidn2 maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libidn2\\Libidn2",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libidn2"
      ],
      "checkIfExists": [
        "brew list libidn2"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libidn2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libidn2"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libidn2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libidn2"
      ]
    },
    "alpine": {
      "install": [
        "apk add libidn2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libidn2"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libidn2-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libidn2"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libidn2-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libidn2"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libidn2": {
      "symbol_prefix": "idn2",
      "library_names": [
        "libidn2.dylib",
        "libidn2.so",
        "idn2.dll"
      ],
      "header_names": [
        "idn2.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
