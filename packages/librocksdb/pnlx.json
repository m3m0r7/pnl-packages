{
  "schema_version": "2026-07-01",
  "name": "librocksdb/librocksdb",
  "version": "9.1.1",
  "description": "PHP FFI wrapper for the RocksDB key-value store.",
  "authors": [
    {
      "name": "RocksDB maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Librocksdb\\Librocksdb",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install rocksdb"
      ],
      "checkIfExists": [
        "brew list rocksdb"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y librocksdb-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q librocksdb"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y librocksdb-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q librocksdb"
      ]
    },
    "alpine": {
      "install": [
        "apk add rocksdb-dev"
      ],
      "checkIfExists": [
        "apk info -e rocksdb-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y rocksdb-devel"
      ],
      "checkIfExists": [
        "rpm -q rocksdb-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y rocksdb-devel"
      ],
      "checkIfExists": [
        "rpm -q rocksdb-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install rocksdb"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "librocksdb": {
      "symbol_prefix": "rocksdb",
      "library_names": [
        "librocksdb.dylib",
        "librocksdb.so",
        "rocksdb.dll"
      ],
      "header_names": [
        "rocksdb/c.h"
      ],
      "version": ">=8.0.0 & <10.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
