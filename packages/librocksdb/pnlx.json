{
  "schema_version": "2026-07-01",
  "name": "librocksdb/librocksdb",
  "version": "9.1.1",
  "description": "PHP FFI wrapper for the RocksDB key-value store.",
  "authors": [
    {
      "name": "RocksDB maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Librocksdb\\Librocksdb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-writebatch.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "librocksdb": {
      "symbol_prefix": "rocksdb",
      "library_names": [
        "librocksdb.dylib",
        "librocksdb.so",
        "rocksdb.dll"
      ],
      "header_names": [
        "rocksdb/c.h"
      ],
      "version": ">=8.0.0 & <10.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install rocksdb"
        ],
        "check_if_exists": [
          "brew list rocksdb"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y librocksdb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q librocksdb"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y librocksdb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q librocksdb"
        ]
      },
      "alpine": {
        "commands": [
          "apk add rocksdb-dev"
        ],
        "check_if_exists": [
          "apk info -e rocksdb-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y rocksdb-devel"
        ],
        "check_if_exists": [
          "rpm -q rocksdb-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y rocksdb-devel"
        ],
        "check_if_exists": [
          "rpm -q rocksdb-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install rocksdb"
        ]
      }
    }
  }
}
