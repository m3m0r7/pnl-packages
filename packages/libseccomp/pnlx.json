{
  "schema_version": "2026-07-01",
  "name": "libseccomp/libseccomp",
  "version": "2.5.5",
  "description": "PHP FFI wrapper for libseccomp Linux syscall filtering (seccomp-bpf).",
  "authors": [
    {
      "name": "libseccomp maintainers"
    }
  ],
  "license": "LGPL-2.1-only",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libseccomp\\Libseccomp",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "libseccomp": {
      "symbol_prefix": "seccomp",
      "library_names": [
        "libseccomp.so"
      ],
      "header_names": [
        "seccomp.h"
      ],
      "version": ">=2.4.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libseccomp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libseccomp"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libseccomp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libseccomp"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libseccomp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libseccomp"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libseccomp-devel"
        ],
        "check_if_exists": [
          "rpm -q libseccomp-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libseccomp-devel"
        ],
        "check_if_exists": [
          "rpm -q libseccomp-devel"
        ]
      }
    }
  }
}
