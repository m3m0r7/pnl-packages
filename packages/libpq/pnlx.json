{
  "schema_version": "2026-07-01",
  "name": "libpq/libpq",
  "version": "16.2",
  "description": "PHP FFI wrapper for the PostgreSQL libpq client.",
  "authors": [
    {
      "name": "libpq maintainers"
    }
  ],
  "license": "PostgreSQL",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpq\\Libpq",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libpq"
      ],
      "checkIfExists": [
        "brew list libpq"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libpq-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libpq"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libpq-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libpq"
      ]
    },
    "alpine": {
      "install": [
        "apk add libpq-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libpq"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libpq-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libpq"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libpq-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libpq"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libpq"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libpq": {
      "symbol_prefix": "PQ",
      "library_names": [
        "libpq.dylib",
        "libpq.so",
        "libpq.dll"
      ],
      "header_names": [
        "libpq-fe.h"
      ],
      "version": ">=12.0.0 & <17.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
