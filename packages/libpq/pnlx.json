{
  "schema_version": "2026-07-01",
  "name": "libpq/libpq",
  "version": "16.2",
  "description": "PHP FFI wrapper for the PostgreSQL libpq client.",
  "authors": [
    {
      "name": "libpq maintainers"
    }
  ],
  "license": "PostgreSQL",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpq\\Libpq",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-encoding.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libpq": {
      "symbol_prefix": "PQ",
      "library_names": [
        "libpq.dylib",
        "libpq.so",
        "libpq.dll"
      ],
      "header_names": [
        "libpq-fe.h"
      ],
      "version": ">=12.0.0 & <17.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libpq"
        ],
        "check_if_exists": [
          "brew list libpq"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpq-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libpq"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpq-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libpq"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libpq-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libpq"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libpq-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libpq"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libpq-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libpq"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libpq"
        ]
      }
    }
  }
}
