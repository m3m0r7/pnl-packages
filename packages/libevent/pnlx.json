{
  "schema_version": "2026-07-01",
  "name": "libevent/libevent",
  "version": "2.1.12",
  "description": "PHP FFI wrapper for the libevent event loop.",
  "authors": [
    {
      "name": "libevent maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libevent\\Libevent",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-introspection.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libevent": {
      "symbol_prefix": "event",
      "library_names": [
        "libevent.dylib",
        "libevent.so",
        "event.dll"
      ],
      "header_names": [
        "event2/event.h"
      ],
      "version": ">=2.1.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libevent"
        ],
        "check_if_exists": [
          "brew list libevent"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libevent-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libevent"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libevent-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libevent"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libevent-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libevent"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libevent-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libevent"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libevent-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libevent"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libevent"
        ]
      }
    }
  }
}
