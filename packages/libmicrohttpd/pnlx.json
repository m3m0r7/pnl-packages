{
  "schema_version": "2026-07-01",
  "name": "libmicrohttpd/libmicrohttpd",
  "version": "1.0.1",
  "description": "PHP FFI wrapper for GNU libmicrohttpd.",
  "authors": [
    {
      "name": "GNU libmicrohttpd maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmicrohttpd\\Libmicrohttpd",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-status-phrases.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmicrohttpd": {
      "symbol_prefix": "MHD",
      "library_names": [
        "libmicrohttpd.dylib",
        "libmicrohttpd.so",
        "microhttpd.dll"
      ],
      "header_names": [
        "microhttpd.h"
      ],
      "version": ">=0.9.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libmicrohttpd"
        ],
        "check_if_exists": [
          "brew list libmicrohttpd"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmicrohttpd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmicrohttpd"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmicrohttpd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmicrohttpd"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libmicrohttpd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmicrohttpd"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libmicrohttpd-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmicrohttpd"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libmicrohttpd-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmicrohttpd"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libmicrohttpd"
        ]
      }
    }
  }
}
