{
  "schema_version": "2026-07-01",
  "name": "libmicrohttpd/libmicrohttpd",
  "version": "1.0.1",
  "description": "PHP FFI wrapper for GNU libmicrohttpd.",
  "authors": [
    {
      "name": "GNU libmicrohttpd maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmicrohttpd\\Libmicrohttpd",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libmicrohttpd"
      ],
      "checkIfExists": [
        "brew list libmicrohttpd"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmicrohttpd-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmicrohttpd"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmicrohttpd-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmicrohttpd"
      ]
    },
    "alpine": {
      "install": [
        "apk add libmicrohttpd-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmicrohttpd"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libmicrohttpd-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libmicrohttpd"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libmicrohttpd-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libmicrohttpd"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libmicrohttpd"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmicrohttpd": {
      "symbol_prefix": "MHD",
      "library_names": [
        "libmicrohttpd.dylib",
        "libmicrohttpd.so",
        "microhttpd.dll"
      ],
      "header_names": [
        "microhttpd.h"
      ],
      "version": ">=0.9.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
