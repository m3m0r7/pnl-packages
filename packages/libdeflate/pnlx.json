{
  "schema_version": "2026-07-01",
  "name": "libdeflate/libdeflate",
  "version": "1.20.0",
  "description": "PHP FFI wrapper for libdeflate fast DEFLATE/zlib/gzip (de)compression.",
  "authors": [
    {
      "name": "libdeflate maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libdeflate\\Libdeflate",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-checksums.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libdeflate": {
      "symbol_prefix": "libdeflate",
      "library_names": [
        "libdeflate.dylib",
        "libdeflate.so",
        "deflate.dll"
      ],
      "header_names": [
        "libdeflate.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libdeflate"
        ],
        "check_if_exists": [
          "brew list libdeflate"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libdeflate-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libdeflate"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libdeflate-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libdeflate"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libdeflate-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libdeflate"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libdeflate-devel"
        ],
        "check_if_exists": [
          "rpm -q libdeflate-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libdeflate-devel"
        ],
        "check_if_exists": [
          "rpm -q libdeflate-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libdeflate"
        ]
      }
    }
  }
}
