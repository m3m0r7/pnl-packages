{
  "schema_version": "2026-07-01",
  "name": "liboniguruma/liboniguruma",
  "version": "6.9.9",
  "description": "PHP FFI wrapper for the Oniguruma regex library.",
  "authors": [
    {
      "name": "Oniguruma maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Liboniguruma\\Liboniguruma",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-runtime-limits.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libonig": {
      "symbol_prefix": "onig",
      "library_names": [
        "libonig.dylib",
        "libonig.so",
        "onig.dll"
      ],
      "header_names": [
        "oniguruma.h"
      ],
      "version": ">=6.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install oniguruma"
        ],
        "check_if_exists": [
          "brew list oniguruma"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libonig-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists oniguruma"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libonig-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists oniguruma"
        ]
      },
      "alpine": {
        "commands": [
          "apk add oniguruma-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists oniguruma"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y oniguruma-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists oniguruma"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y oniguruma-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists oniguruma"
        ]
      }
    }
  }
}
