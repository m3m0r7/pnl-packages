{
  "schema_version": "2026-07-01",
  "name": "libenet/libenet",
  "version": "1.3.18",
  "description": "PHP FFI wrapper for ENet reliable UDP networking.",
  "authors": [
    {
      "name": "ENet maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libenet\\Libenet",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-timing.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "enet": {
      "symbol_prefix": "enet",
      "library_names": [
        "libenet.dylib",
        "libenet.so",
        "enet.dll"
      ],
      "header_names": [
        "enet/enet.h"
      ],
      "version": ">=1.3.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install enet"
        ],
        "check_if_exists": [
          "brew list enet"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libenet-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libenet"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libenet-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libenet"
        ]
      },
      "alpine": {
        "commands": [
          "apk add enet-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libenet"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y enet-devel"
        ],
        "check_if_exists": [
          "rpm -q enet-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y enet-devel"
        ],
        "check_if_exists": [
          "rpm -q enet-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install enet"
        ]
      }
    }
  }
}
