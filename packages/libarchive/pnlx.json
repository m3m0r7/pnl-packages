{
  "schema_version": "2026-07-01",
  "name": "libarchive/libarchive",
  "version": "3.7.4",
  "description": "PHP FFI wrapper for libarchive multi-format archive I/O.",
  "authors": [
    {
      "name": "libarchive maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libarchive\\Libarchive",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libarchive": {
      "symbol_prefix": "archive",
      "library_names": [
        "libarchive.dylib",
        "libarchive.so",
        "archive.dll"
      ],
      "header_names": [
        "archive.h",
        "archive_entry.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libarchive"
        ],
        "check_if_exists": [
          "brew list libarchive"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libarchive-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libarchive"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libarchive-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libarchive"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libarchive-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libarchive"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libarchive-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libarchive"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libarchive-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libarchive"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libarchive"
        ]
      }
    }
  }
}
