{
  "schema_version": "2026-07-01",
  "name": "libarchive/libarchive",
  "version": "3.7.4",
  "description": "PHP FFI wrapper for libarchive multi-format archive I/O.",
  "authors": [
    {
      "name": "libarchive maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libarchive\\Libarchive",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libarchive"
      ],
      "checkIfExists": [
        "brew list libarchive"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libarchive-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libarchive"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libarchive-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libarchive"
      ]
    },
    "alpine": {
      "install": [
        "apk add libarchive-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libarchive"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libarchive-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libarchive"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libarchive-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libarchive"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libarchive"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libarchive": {
      "symbol_prefix": "archive",
      "library_names": [
        "libarchive.dylib",
        "libarchive.so",
        "archive.dll"
      ],
      "header_names": [
        "archive.h",
        "archive_entry.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
