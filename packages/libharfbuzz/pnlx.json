{
  "schema_version": "2026-07-01",
  "name": "libharfbuzz/libharfbuzz",
  "version": "8.4.0",
  "description": "PHP FFI wrapper for the HarfBuzz text shaping engine.",
  "authors": [
    {
      "name": "HarfBuzz maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libharfbuzz\\Libharfbuzz",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install harfbuzz"
      ],
      "checkIfExists": [
        "brew list harfbuzz"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libharfbuzz-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists harfbuzz"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libharfbuzz-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists harfbuzz"
      ]
    },
    "alpine": {
      "install": [
        "apk add harfbuzz-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists harfbuzz"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y harfbuzz-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists harfbuzz"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y harfbuzz-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists harfbuzz"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install harfbuzz"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libharfbuzz": {
      "symbol_prefix": "hb",
      "library_names": [
        "libharfbuzz.dylib",
        "libharfbuzz.so",
        "harfbuzz.dll"
      ],
      "header_names": [
        "harfbuzz/hb.h"
      ],
      "version": ">=6.0.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
