{
  "schema_version": "2026-07-01",
  "name": "libharfbuzz/libharfbuzz",
  "version": "8.4.0",
  "description": "PHP FFI wrapper for the HarfBuzz text shaping engine.",
  "authors": [
    {
      "name": "HarfBuzz maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libharfbuzz\\Libharfbuzz",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-scripts-and-tags.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libharfbuzz": {
      "symbol_prefix": "hb",
      "library_names": [
        "libharfbuzz.dylib",
        "libharfbuzz.so",
        "harfbuzz.dll"
      ],
      "header_names": [
        "harfbuzz/hb.h"
      ],
      "version": ">=6.0.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install harfbuzz"
        ],
        "check_if_exists": [
          "brew list harfbuzz"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libharfbuzz-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists harfbuzz"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libharfbuzz-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists harfbuzz"
        ]
      },
      "alpine": {
        "commands": [
          "apk add harfbuzz-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists harfbuzz"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y harfbuzz-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists harfbuzz"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y harfbuzz-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists harfbuzz"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install harfbuzz"
        ]
      }
    }
  }
}
