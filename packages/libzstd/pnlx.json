{
  "schema_version": "2026-07-01",
  "name": "libzstd/libzstd",
  "version": "1.5.6",
  "description": "PHP FFI wrapper for Zstandard compression.",
  "authors": [
    {
      "name": "Zstandard maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzstd\\Libzstd",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-levels.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libzstd": {
      "symbol_prefix": "ZSTD",
      "library_names": [
        "libzstd.dylib",
        "libzstd.so",
        "zstd.dll"
      ],
      "header_names": [
        "zstd.h"
      ],
      "version": ">=1.4.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install zstd"
        ],
        "check_if_exists": [
          "brew list zstd"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libzstd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzstd"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libzstd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzstd"
        ]
      },
      "alpine": {
        "commands": [
          "apk add zstd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzstd"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libzstd-devel"
        ],
        "check_if_exists": [
          "rpm -q libzstd-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libzstd-devel"
        ],
        "check_if_exists": [
          "rpm -q libzstd-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install zstd"
        ]
      }
    }
  }
}
