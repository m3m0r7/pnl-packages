{
  "schema_version": "2026-07-01",
  "name": "libzstd/libzstd",
  "version": "1.5.6",
  "description": "PHP FFI wrapper for Zstandard compression.",
  "authors": [
    {
      "name": "Zstandard maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzstd\\Libzstd",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install zstd"
      ],
      "checkIfExists": [
        "brew list zstd"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libzstd-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzstd"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libzstd-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzstd"
      ]
    },
    "alpine": {
      "install": [
        "apk add zstd-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzstd"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libzstd-devel"
      ],
      "checkIfExists": [
        "rpm -q libzstd-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libzstd-devel"
      ],
      "checkIfExists": [
        "rpm -q libzstd-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install zstd"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libzstd": {
      "symbol_prefix": "ZSTD",
      "library_names": [
        "libzstd.dylib",
        "libzstd.so",
        "zstd.dll"
      ],
      "header_names": [
        "zstd.h"
      ],
      "version": ">=1.4.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
