{
  "schema_version": "2026-07-01",
  "name": "libunbound/libunbound",
  "version": "1.22.0",
  "description": "PHP FFI wrapper for libunbound, the recursive DNS resolver library.",
  "authors": [
    {
      "name": "Libunbound maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libunbound\\Libunbound",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strerror.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "unbound": {
      "symbol_prefix": "ub",
      "library_names": [
        "libunbound.dylib",
        "libunbound.so",
        "unbound.dll"
      ],
      "header_names": [
        "unbound.h"
      ],
      "version": ">=1.10.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install unbound"
        ],
        "check_if_exists": [
          "brew list unbound"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libunbound-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libunbound"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libunbound-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libunbound"
        ]
      },
      "alpine": {
        "commands": [
          "apk add unbound-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libunbound"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y unbound-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libunbound"
        ]
      }
    }
  }
}
