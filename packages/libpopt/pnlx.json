{
  "schema_version": "2026-07-01",
  "name": "libpopt/libpopt",
  "version": "1.19.0",
  "description": "PHP FFI wrapper for the popt command-line option parser.",
  "authors": [
    {
      "name": "popt maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpopt\\Libpopt",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-file-sanity.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "popt": {
      "symbol_prefix": "popt",
      "library_names": [
        "libpopt.dylib",
        "libpopt.so",
        "popt.dll"
      ],
      "header_names": [
        "popt.h"
      ],
      "version": ">=1.16.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install popt"
        ],
        "check_if_exists": [
          "brew list popt"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpopt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists popt"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpopt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists popt"
        ]
      },
      "alpine": {
        "commands": [
          "apk add popt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists popt"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y popt-devel"
        ],
        "check_if_exists": [
          "rpm -q popt-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y popt-devel"
        ],
        "check_if_exists": [
          "rpm -q popt-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install popt"
        ]
      }
    }
  }
}
