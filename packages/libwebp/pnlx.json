{
  "schema_version": "2026-07-01",
  "name": "libwebp/libwebp",
  "version": "1.4.0",
  "description": "PHP FFI wrapper for WebP image codec.",
  "authors": [
    {
      "name": "libwebp maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libwebp\\Libwebp",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-encoder-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libwebp": {
      "symbol_prefix": "WebP",
      "library_names": [
        "libwebp.dylib",
        "libwebp.so",
        "webp.dll"
      ],
      "header_names": [
        "webp/decode.h",
        "webp/encode.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install webp"
        ],
        "check_if_exists": [
          "brew list webp"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libwebp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebp"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libwebp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebp"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libwebp-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebp"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libwebp-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebp"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libwebp-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebp"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libwebp"
        ]
      }
    }
  }
}
