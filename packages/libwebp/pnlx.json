{
  "schema_version": "2026-07-01",
  "name": "libwebp/libwebp",
  "version": "1.4.0",
  "description": "PHP FFI wrapper for WebP image codec.",
  "authors": [
    {
      "name": "libwebp maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libwebp\\Libwebp",
  "examples": [
    "use Pnlx\\Libwebp\\Libwebp;\nuse Pnlx\\Runtime;\n\n$runtime = new Runtime(__DIR__);\n$libwebp = $runtime->load(Libwebp::class);\n\n// WebPGetDecoderVersion() returns version as (major<<16|minor<<8|revision).\n$ver = $libwebp->WebPGetDecoderVersion();\necho sprintf(\"libwebp decoder %d.%d.%d\\n\",\n    ($ver >> 16) & 0xff, ($ver >> 8) & 0xff, $ver & 0xff);\n\n// Explore further: WebPDecodeRGBA(), WebPEncodeRGB(), WebPGetInfo(), ..."
  ],
  "installation": {
    "darwin": {
      "install": ["brew install webp"],
      "checkIfExists": ["brew list webp"]
    },
    "linux": {
      "install": ["sudo apt-get install -y libwebp-dev"],
      "checkIfExists": ["pkg-config --exists libwebp"]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libwebp": {
      "symbol_prefix": "WebP",
      "library_names": [
        "libwebp.dylib",
        "libwebp.so",
        "webp.dll"
      ],
      "header_names": [
        "webp/decode.h",
        "webp/encode.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
