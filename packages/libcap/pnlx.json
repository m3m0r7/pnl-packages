{
  "schema_version": "2026-07-01",
  "name": "libcap/libcap",
  "version": "2.69.0",
  "description": "PHP FFI wrapper for libcap POSIX capabilities management on Linux.",
  "authors": [
    {
      "name": "libcap maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcap\\Libcap",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "libcap": {
      "symbol_prefix": "cap",
      "library_names": [
        "libcap.so"
      ],
      "header_names": [
        "sys/capability.h"
      ],
      "version": ">=2.40.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcap-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcap"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcap-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcap"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libcap-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcap"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libcap-devel"
        ],
        "check_if_exists": [
          "rpm -q libcap-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libcap-devel"
        ],
        "check_if_exists": [
          "rpm -q libcap-devel"
        ]
      }
    }
  }
}
