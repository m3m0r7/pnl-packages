{
  "schema_version": "2026-07-01",
  "name": "libgd/libgd",
  "version": "2.3.3",
  "description": "PHP FFI wrapper for the GD graphics library.",
  "authors": [
    {
      "name": "GD maintainers"
    }
  ],
  "license": "GD",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgd\\Libgd",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libgd": {
      "symbol_prefix": "gd",
      "library_names": [
        "libgd.dylib",
        "libgd.so",
        "gd.dll"
      ],
      "header_names": [
        "gd.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install gd"
        ],
        "check_if_exists": [
          "brew list gd"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gdlib"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gdlib"
        ]
      },
      "alpine": {
        "commands": [
          "apk add gd-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists gdlib"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y gd-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists gdlib"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y gd-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists gdlib"
        ]
      }
    }
  }
}
