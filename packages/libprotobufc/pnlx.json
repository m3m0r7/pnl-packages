{
  "schema_version": "2026-07-01",
  "name": "libprotobufc/libprotobufc",
  "version": "1.5.0",
  "description": "PHP FFI wrapper for the protobuf-c library.",
  "authors": [
    {
      "name": "protobuf-c maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libprotobufc\\Libprotobufc",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libprotobuf-c": {
      "symbol_prefix": "protobuf_c",
      "library_names": [
        "libprotobuf-c.dylib",
        "libprotobuf-c.so",
        "protobuf-c.dll"
      ],
      "header_names": [
        "protobuf-c/protobuf-c.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install protobuf-c"
        ],
        "check_if_exists": [
          "brew list protobuf-c"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libprotobuf-c-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libprotobuf-c"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libprotobuf-c-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libprotobuf-c"
        ]
      },
      "alpine": {
        "commands": [
          "apk add protobuf-c-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libprotobuf-c"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y protobuf-c-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libprotobuf-c"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y protobuf-c-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libprotobuf-c"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install protobuf-c"
        ]
      }
    }
  }
}
