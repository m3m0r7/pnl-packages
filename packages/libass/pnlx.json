{
  "schema_version": "2026-07-01",
  "name": "libass/libass",
  "version": "0.17.3",
  "description": "PHP FFI wrapper for libass ASS/SSA subtitle rendering.",
  "authors": [
    {
      "name": "libass maintainers"
    }
  ],
  "license": "ISC",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libass\\Libass",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libass": {
      "symbol_prefix": "ass",
      "library_names": [
        "libass.dylib",
        "libass.so",
        "ass.dll"
      ],
      "header_names": [
        "ass/ass.h"
      ],
      "version": ">=0.15.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libass"
        ],
        "check_if_exists": [
          "brew list libass"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libass-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libass"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libass-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libass"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libass-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libass"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libass-devel"
        ],
        "check_if_exists": [
          "rpm -q libass-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libass-devel"
        ],
        "check_if_exists": [
          "rpm -q libass-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libass"
        ]
      }
    }
  }
}
