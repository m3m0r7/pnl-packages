{
  "schema_version": "2026-07-01",
  "name": "libsndfile/libsndfile",
  "version": "1.2.2",
  "description": "PHP FFI wrapper for libsndfile audio I/O.",
  "authors": [
    {
      "name": "libsndfile maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsndfile\\Libsndfile",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "sndfile": {
      "symbol_prefix": "sf",
      "library_names": [
        "libsndfile.dylib",
        "libsndfile.so",
        "sndfile.dll"
      ],
      "header_names": [
        "sndfile.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libsndfile"
        ],
        "check_if_exists": [
          "brew list libsndfile"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsndfile1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists sndfile"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsndfile1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists sndfile"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libsndfile-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists sndfile"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libsndfile-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists sndfile"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libsndfile-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists sndfile"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libsndfile"
        ]
      }
    }
  }
}
