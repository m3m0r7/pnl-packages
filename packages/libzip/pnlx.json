{
  "schema_version": "2026-07-01",
  "name": "libzip/libzip",
  "version": "1.10.1",
  "description": "PHP FFI wrapper for libzip archive handling.",
  "authors": [
    {
      "name": "libzip maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzip\\Libzip",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-capabilities.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libzip": {
      "symbol_prefix": "zip",
      "library_names": [
        "libzip.dylib",
        "libzip.so",
        "zip.dll"
      ],
      "header_names": [
        "zip.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libzip"
        ],
        "check_if_exists": [
          "brew list libzip"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libzip-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzip"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libzip-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzip"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libzip-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzip"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libzip-devel"
        ],
        "check_if_exists": [
          "rpm -q libzip-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libzip-devel"
        ],
        "check_if_exists": [
          "rpm -q libzip-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libzip"
        ]
      }
    }
  }
}
