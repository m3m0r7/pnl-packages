{
  "schema_version": "2026-07-01",
  "name": "libzip/libzip",
  "version": "1.10.1",
  "description": "PHP FFI wrapper for libzip archive handling.",
  "authors": [
    {
      "name": "libzip maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzip\\Libzip",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libzip"
      ],
      "checkIfExists": [
        "brew list libzip"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libzip-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzip"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libzip-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzip"
      ]
    },
    "alpine": {
      "install": [
        "apk add libzip-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzip"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libzip-devel"
      ],
      "checkIfExists": [
        "rpm -q libzip-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libzip-devel"
      ],
      "checkIfExists": [
        "rpm -q libzip-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libzip"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libzip": {
      "symbol_prefix": "zip",
      "library_names": [
        "libzip.dylib",
        "libzip.so",
        "zip.dll"
      ],
      "header_names": [
        "zip.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
