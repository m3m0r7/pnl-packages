{
  "schema_version": "2026-07-01",
  "name": "libapr/libapr",
  "version": "1.7.6",
  "description": "PHP FFI wrapper for the Apache Portable Runtime (APR).",
  "authors": [
    {
      "name": "APR maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libapr\\Libapr",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version-parts.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "apr-1": {
      "symbol_prefix": "apr",
      "library_names": [
        "libapr-1.dylib",
        "libapr-1.so",
        "apr-1.dll"
      ],
      "header_names": [
        "apr.h",
        "apr_version.h"
      ],
      "version": ">=1.5.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install apr"
        ],
        "check_if_exists": [
          "brew list apr"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libapr1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists apr-1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libapr1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists apr-1"
        ]
      },
      "alpine": {
        "commands": [
          "apk add apr-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists apr-1"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y apr-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists apr-1"
        ]
      }
    }
  }
}
