{
  "schema_version": "2026-07-01",
  "name": "libproj/libproj",
  "version": "9.4.0",
  "description": "PHP FFI wrapper for PROJ cartographic projections and transforms.",
  "authors": [
    {
      "name": "OSGeo / PROJ maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libproj\\Libproj",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install proj"
      ],
      "checkIfExists": [
        "brew list proj"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libproj-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists proj"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libproj-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists proj"
      ]
    },
    "alpine": {
      "install": [
        "apk add proj-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists proj"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y proj-devel"
      ],
      "checkIfExists": [
        "rpm -q proj-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y proj-devel"
      ],
      "checkIfExists": [
        "rpm -q proj-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install proj"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "proj": {
      "symbol_prefix": "proj",
      "library_names": [
        "libproj.dylib",
        "libproj.so",
        "proj.dll"
      ],
      "header_names": [
        "proj.h"
      ],
      "version": ">=8.0.0 & <10.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
