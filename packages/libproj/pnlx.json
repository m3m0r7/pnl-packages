{
  "schema_version": "2026-07-01",
  "name": "libproj/libproj",
  "version": "9.4.0",
  "description": "PHP FFI wrapper for PROJ cartographic projections and transforms.",
  "authors": [
    {
      "name": "OSGeo / PROJ maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libproj\\Libproj",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-angles.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "proj": {
      "symbol_prefix": "proj",
      "library_names": [
        "libproj.dylib",
        "libproj.so",
        "proj.dll"
      ],
      "header_names": [
        "proj.h"
      ],
      "version": ">=8.0.0 & <10.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install proj"
        ],
        "check_if_exists": [
          "brew list proj"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libproj-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists proj"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libproj-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists proj"
        ]
      },
      "alpine": {
        "commands": [
          "apk add proj-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists proj"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y proj-devel"
        ],
        "check_if_exists": [
          "rpm -q proj-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y proj-devel"
        ],
        "check_if_exists": [
          "rpm -q proj-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install proj"
        ]
      }
    }
  }
}
