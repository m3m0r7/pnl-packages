{
  "schema_version": "2026-07-01",
  "name": "libnfc/libnfc",
  "version": "1.8.0",
  "description": "PHP FFI wrapper for libnfc.",
  "authors": [
    {
      "name": "libnfc maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnfc\\Libnfc",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-enum-labels.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64",
      "libc": "glibc"
    },
    {
      "os": "linux",
      "arch": "aarch64",
      "libc": "glibc"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libnfc": {
      "symbol_prefix": "nfc",
      "library_names": [
        "libnfc.dylib",
        "libnfc.so",
        "libnfc.dll"
      ],
      "header_names": [
        "nfc/nfc.h",
        "nfc/nfc-types.h",
        "nfc/nfc-emulation.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libnfc"
        ],
        "check_if_exists": [
          "brew list libnfc"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libnfc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libnfc"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libnfc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libnfc"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libnfc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libnfc"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libnfc-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libnfc"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libnfc-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libnfc"
        ]
      }
    }
  }
}
