{
  "schema_version": "2026-07-01",
  "name": "libnfc/libnfc",
  "version": "1.8.0",
  "description": "PHP FFI wrapper for libnfc.",
  "authors": [
    {
      "name": "libnfc maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libnfc\\Libnfc",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libnfc"
      ],
      "checkIfExists": [
        "brew list libnfc"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libnfc-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libnfc"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libnfc-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libnfc"
      ]
    },
    "alpine": {
      "install": [
        "apk add libnfc-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libnfc"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libnfc-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libnfc"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libnfc-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libnfc"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64",
      "libc": "glibc"
    },
    {
      "os": "linux",
      "arch": "aarch64",
      "libc": "glibc"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libnfc": {
      "symbol_prefix": "nfc",
      "library_names": [
        "libnfc.dylib",
        "libnfc.so",
        "libnfc.dll"
      ],
      "header_names": [
        "nfc/nfc.h",
        "nfc/nfc-types.h",
        "nfc/nfc-emulation.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
