{
  "schema_version": "2026-07-01",
  "name": "libavformat/libavformat",
  "version": "61.1.100",
  "description": "PHP FFI wrapper for FFmpeg libavformat.",
  "authors": [
    {
      "name": "FFmpeg libavformat maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libavformat\\Libavformat",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-networking.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libavformat": {
      "symbol_prefix": "avformat",
      "library_names": [
        "libavformat.dylib",
        "libavformat.so",
        "avformat.dll"
      ],
      "header_names": [
        "libavformat/avformat.h"
      ],
      "version": ">=58.0.0 & <62.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ffmpeg"
        ],
        "check_if_exists": [
          "brew list ffmpeg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libavformat-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavformat"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libavformat-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavformat"
        ]
      },
      "alpine": {
        "commands": [
          "apk add ffmpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavformat"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavformat"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavformat"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install ffmpeg"
        ]
      }
    }
  }
}
