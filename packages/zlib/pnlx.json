{
  "schema_version": "2026-07-01",
  "name": "zlib/zlib",
  "version": "1.3.1",
  "description": "PHP FFI wrapper for zlib compression.",
  "authors": [
    {
      "name": "zlib maintainers"
    }
  ],
  "license": "Zlib",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Zlib\\Zlib",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-checksums.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "zlib": {
      "library_names": [
        "libz.dylib",
        "libz.so",
        "zlib1.dll"
      ],
      "header_names": [
        "zlib.h"
      ],
      "version": ">=1.2.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install zlib"
        ],
        "check_if_exists": [
          "brew list zlib"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y zlib1g-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists zlib"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y zlib1g-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists zlib"
        ]
      },
      "alpine": {
        "commands": [
          "apk add zlib-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists zlib"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y zlib-devel"
        ],
        "check_if_exists": [
          "rpm -q zlib-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y zlib-devel"
        ],
        "check_if_exists": [
          "rpm -q zlib-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install zlib"
        ]
      }
    }
  }
}
