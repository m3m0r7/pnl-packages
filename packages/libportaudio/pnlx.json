{
  "schema_version": "2026-07-01",
  "name": "libportaudio/libportaudio",
  "version": "19.7.0",
  "description": "PHP FFI wrapper for PortAudio audio I/O.",
  "authors": [
    {
      "name": "PortAudio maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libportaudio\\Libportaudio",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libportaudio": {
      "symbol_prefix": "Pa",
      "library_names": [
        "libportaudio.dylib",
        "libportaudio.so",
        "portaudio.dll"
      ],
      "header_names": [
        "portaudio.h"
      ],
      "version": ">=19.0.0 & <20.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install portaudio"
        ],
        "check_if_exists": [
          "brew list portaudio"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y portaudio19-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists portaudio-2.0"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y portaudio19-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists portaudio-2.0"
        ]
      },
      "alpine": {
        "commands": [
          "apk add portaudio-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists portaudio-2.0"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y portaudio-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists portaudio-2.0"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y portaudio-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists portaudio-2.0"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install portaudio"
        ]
      }
    }
  }
}
