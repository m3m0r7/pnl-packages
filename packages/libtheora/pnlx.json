{
  "schema_version": "2026-07-01",
  "name": "libtheora/libtheora",
  "version": "1.1.1",
  "description": "PHP FFI wrapper for the Theora video codec.",
  "authors": [
    {
      "name": "Xiph.Org / Theora maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtheora\\Libtheora",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-th-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "theora": {
      "symbol_prefix": "th",
      "library_names": [
        "libtheora.dylib",
        "libtheora.so",
        "theora.dll"
      ],
      "header_names": [
        "theora/theora.h",
        "theora/codec.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install theora"
        ],
        "check_if_exists": [
          "brew list theora"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtheora-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists theora"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtheora-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists theora"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libtheora-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists theora"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libtheora-devel"
        ],
        "check_if_exists": [
          "rpm -q libtheora-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libtheora-devel"
        ],
        "check_if_exists": [
          "rpm -q libtheora-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libtheora"
        ]
      }
    }
  }
}
