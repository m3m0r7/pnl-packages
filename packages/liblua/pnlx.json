{
  "schema_version": "2026-07-01",
  "name": "liblua/liblua",
  "version": "5.4.6",
  "description": "PHP FFI wrapper for the Lua interpreter.",
  "authors": [
    {
      "name": "Lua maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Liblua\\Liblua",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install lua"
      ],
      "checkIfExists": [
        "brew list lua"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y liblua5.4-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q liblua"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y liblua5.4-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q liblua"
      ]
    },
    "alpine": {
      "install": [
        "apk add lua5.4-dev"
      ],
      "checkIfExists": [
        "apk info -e lua5.4-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y lua-devel"
      ],
      "checkIfExists": [
        "rpm -q lua-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y lua-devel"
      ],
      "checkIfExists": [
        "rpm -q lua-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install lua"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "liblua": {
      "symbol_prefix": "lua",
      "library_names": [
        "liblua.dylib",
        "liblua.so",
        "lua54.dll",
        "liblua5.4.so",
        "liblua-5.4.so"
      ],
      "header_names": [
        "lua.h",
        "lauxlib.h",
        "lualib.h",
        "lua5.4/lua.h",
        "lua5.4/lauxlib.h",
        "lua5.4/lualib.h"
      ],
      "version": ">=5.1.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
