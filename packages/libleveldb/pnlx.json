{
  "schema_version": "2026-07-01",
  "name": "libleveldb/libleveldb",
  "version": "1.23",
  "description": "PHP FFI wrapper for the LevelDB key-value store.",
  "authors": [
    {
      "name": "LevelDB maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libleveldb\\Libleveldb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libleveldb": {
      "symbol_prefix": "leveldb",
      "library_names": [
        "libleveldb.dylib",
        "libleveldb.so",
        "leveldb.dll"
      ],
      "header_names": [
        "leveldb/c.h"
      ],
      "version": ">=1.20.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install leveldb"
        ],
        "check_if_exists": [
          "brew list leveldb"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libleveldb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libleveldb"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libleveldb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libleveldb"
        ]
      },
      "alpine": {
        "commands": [
          "apk add leveldb-dev"
        ],
        "check_if_exists": [
          "apk info -e leveldb-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y leveldb-devel"
        ],
        "check_if_exists": [
          "rpm -q leveldb-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y leveldb-devel"
        ],
        "check_if_exists": [
          "rpm -q leveldb-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install leveldb"
        ]
      }
    }
  }
}
