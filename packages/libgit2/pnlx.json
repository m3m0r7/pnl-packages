{
  "schema_version": "2026-07-01",
  "name": "libgit2/libgit2",
  "version": "1.7.2",
  "description": "PHP FFI wrapper for libgit2.",
  "authors": [
    {
      "name": "libgit2 maintainers"
    }
  ],
  "license": "GPL-2.0-with-GCC-exception",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgit2\\Libgit2",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-features.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libgit2": {
      "symbol_prefix": "git",
      "library_names": [
        "libgit2.dylib",
        "libgit2.so",
        "git2.dll"
      ],
      "header_names": [
        "git2.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libgit2"
        ],
        "check_if_exists": [
          "brew list libgit2"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgit2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libgit2"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgit2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libgit2"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libgit2-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libgit2"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libgit2-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libgit2"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libgit2-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libgit2"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libgit2"
        ]
      }
    }
  }
}
