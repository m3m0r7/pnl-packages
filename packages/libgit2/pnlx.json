{
  "schema_version": "2026-07-01",
  "name": "libgit2/libgit2",
  "version": "1.7.2",
  "description": "PHP FFI wrapper for libgit2.",
  "authors": [
    {
      "name": "libgit2 maintainers"
    }
  ],
  "license": "GPL-2.0-with-GCC-exception",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgit2\\Libgit2",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libgit2"
      ],
      "checkIfExists": [
        "brew list libgit2"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libgit2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libgit2"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libgit2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libgit2"
      ]
    },
    "alpine": {
      "install": [
        "apk add libgit2-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libgit2"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libgit2-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libgit2"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libgit2-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libgit2"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libgit2"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libgit2": {
      "symbol_prefix": "git",
      "library_names": [
        "libgit2.dylib",
        "libgit2.so",
        "git2.dll"
      ],
      "header_names": [
        "git2.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
