{
  "schema_version": "2026-07-01",
  "name": "libzimg/libzimg",
  "version": "3.0.5",
  "description": "PHP FFI wrapper for zimg, the scaling, colorspace and depth library.",
  "authors": [
    {
      "name": "Libzimg maintainers"
    }
  ],
  "license": "WTFPL",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzimg\\Libzimg",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-buffer-math.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "zimg": {
      "symbol_prefix": "zimg",
      "library_names": [
        "libzimg.dylib",
        "libzimg.so",
        "zimg.dll"
      ],
      "header_names": [
        "zimg.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install zimg"
        ],
        "check_if_exists": [
          "brew list zimg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libzimg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists zimg"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libzimg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists zimg"
        ]
      },
      "alpine": {
        "commands": [
          "apk add zimg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists zimg"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y zimg-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists zimg"
        ]
      }
    }
  }
}
