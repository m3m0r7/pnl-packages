{
  "schema_version": "2026-07-01",
  "name": "libzimg/libzimg",
  "version": "3.0.5",
  "description": "PHP FFI wrapper for zimg, the scaling, colorspace and depth library.",
  "authors": [
    {
      "name": "Libzimg maintainers"
    }
  ],
  "license": "WTFPL",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzimg\\Libzimg",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install zimg"
      ],
      "checkIfExists": [
        "brew list zimg"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libzimg-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists zimg"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libzimg-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists zimg"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y zimg-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists zimg"
      ]
    }
  },
  "platforms": [
    { "os": "darwin", "arch": "aarch64" },
    { "os": "darwin", "arch": "x86_64" },
    { "os": "linux", "arch": "x86_64" },
    { "os": "linux", "arch": "aarch64" }
  ],
  "requires": {
    "zimg": {
      "symbol_prefix": "zimg",
      "library_names": [
        "libzimg.dylib",
        "libzimg.so",
        "zimg.dll"
      ],
      "header_names": [
        "zimg.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
