{
  "schema_version": "2026-07-01",
  "name": "libldns/libldns",
  "version": "1.8.4",
  "description": "PHP FFI wrapper for ldns, the NLnet Labs DNS library.",
  "authors": [
    {
      "name": "Libldns maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libldns\\Libldns",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-rrtype.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "ldns": {
      "symbol_prefix": "ldns",
      "library_names": [
        "libldns.dylib",
        "libldns.so",
        "ldns.dll"
      ],
      "header_names": [
        "ldns/ldns.h"
      ],
      "version": ">=1.6.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ldns"
        ],
        "check_if_exists": [
          "brew list ldns"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libldns-dev"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libldns-dev"
        ]
      },
      "alpine": {
        "commands": [
          "apk add ldns-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libldns"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y ldns-devel"
        ]
      }
    }
  }
}
