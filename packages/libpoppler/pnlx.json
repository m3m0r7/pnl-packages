{
  "schema_version": "2026-07-01",
  "name": "libpoppler/libpoppler",
  "version": "24.4.0",
  "description": "PHP FFI wrapper for Poppler (glib API), the PDF rendering library.",
  "authors": [
    {
      "name": "Libpoppler maintainers"
    }
  ],
  "license": "GPL-2.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpoppler\\Libpoppler",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-backend.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "poppler": {
      "symbol_prefix": "poppler",
      "library_names": [
        "libpoppler-glib.dylib",
        "libpoppler-glib.so",
        "poppler-glib.dll"
      ],
      "header_names": [
        "poppler/glib/poppler.h"
      ],
      "version": ">=20.0.0 & <26.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install poppler"
        ],
        "check_if_exists": [
          "brew list poppler"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpoppler-glib-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists poppler-glib"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpoppler-glib-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists poppler-glib"
        ]
      },
      "alpine": {
        "commands": [
          "apk add poppler-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists poppler-glib"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y poppler-glib-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists poppler-glib"
        ]
      }
    }
  }
}
