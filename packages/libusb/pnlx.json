{
  "schema_version": "2026-07-01",
  "name": "libusb/libusb",
  "version": "1.0.29",
  "description": "PHP FFI wrapper for libusb-1.0.",
  "authors": [
    {
      "name": "libusb maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libusb\\Libusb",
  "examples": [
    "use Pnlx\\Libusb\\Libusb;\nuse Pnlx\\Runtime;\n\n$runtime = new Runtime(__DIR__);\n$usb = $runtime->load(Libusb::class);\n\nif ($usb->libusb_init(null) !== 0) {\n    throw new RuntimeException('libusb_init failed');\n}\ntry {\n    // ... enumerate and talk to USB devices ...\n} finally {\n    $usb->libusb_exit(null);\n}"
  ],
  "installation": {
    "darwin": {
      "install": ["brew install libusb"],
      "checkIfExists": ["brew list libusb"]
    },
    "linux": {
      "install": ["sudo apt-get install -y libusb-1.0-0-dev"],
      "checkIfExists": ["pkg-config --exists libusb-1.0"]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libusb-1.0": {
      "symbol_prefix": "libusb",
      "library_names": [
        "libusb-1.0.dylib",
        "libusb-1.0.so",
        "libusb-1.0.dll"
      ],
      "header_names": [
        "libusb-1.0/libusb.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
