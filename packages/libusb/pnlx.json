{
  "schema_version": "2026-07-01",
  "name": "libusb/libusb",
  "version": "1.0.29",
  "description": "PHP FFI wrapper for libusb-1.0.",
  "authors": [
    {
      "name": "libusb maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libusb\\Libusb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libusb-1.0": {
      "symbol_prefix": "libusb",
      "library_names": [
        "libusb-1.0.dylib",
        "libusb-1.0.so",
        "libusb-1.0.dll"
      ],
      "header_names": [
        "libusb-1.0/libusb.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libusb"
        ],
        "check_if_exists": [
          "brew list libusb"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libusb-1.0-0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libusb-1.0"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libusb-1.0-0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libusb-1.0"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libusb-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libusb-1.0"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libusb1-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libusb-1.0"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libusb1-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libusb-1.0"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libusb"
        ]
      }
    }
  }
}
