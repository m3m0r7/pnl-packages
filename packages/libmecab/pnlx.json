{
  "schema_version": "2026-07-01",
  "name": "libmecab/libmecab",
  "version": "0.996.0",
  "description": "PHP FFI wrapper for MeCab, the Japanese morphological analyzer.",
  "authors": [
    {
      "name": "MeCab maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmecab\\Libmecab",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-nbest.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "mecab": {
      "symbol_prefix": "mecab",
      "library_names": [
        "libmecab.dylib",
        "libmecab.so",
        "mecab.dll"
      ],
      "header_names": [
        "mecab.h"
      ],
      "version": ">=0.996.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mecab mecab-ipadic"
        ],
        "check_if_exists": [
          "brew list mecab"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmecab-dev mecab-ipadic-utf8"
        ],
        "check_if_exists": [
          "mecab-config --version"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmecab-dev mecab-ipadic-utf8"
        ],
        "check_if_exists": [
          "mecab-config --version"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mecab-devel"
        ],
        "check_if_exists": [
          "mecab-config --version"
        ]
      }
    }
  }
}
