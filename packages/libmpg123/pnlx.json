{
  "schema_version": "2026-07-01",
  "name": "libmpg123/libmpg123",
  "version": "1.32.6",
  "description": "PHP FFI wrapper for the mpg123 MP3 decoder.",
  "authors": [
    {
      "name": "mpg123 maintainers"
    }
  ],
  "license": "LGPL-2.1-only",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmpg123\\Libmpg123",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-error-strings.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmpg123": {
      "symbol_prefix": "mpg123",
      "library_names": [
        "libmpg123.dylib",
        "libmpg123.so",
        "mpg123.dll"
      ],
      "header_names": [
        "mpg123.h"
      ],
      "version": ">=1.30.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mpg123"
        ],
        "check_if_exists": [
          "brew list mpg123"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmpg123-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists mpg123"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmpg123-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists mpg123"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mpg123-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists mpg123"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mpg123-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists mpg123"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y mpg123-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists mpg123"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install mpg123"
        ]
      }
    }
  }
}
