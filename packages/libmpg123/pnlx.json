{
  "schema_version": "2026-07-01",
  "name": "libmpg123/libmpg123",
  "version": "1.32.6",
  "description": "PHP FFI wrapper for the mpg123 MP3 decoder.",
  "authors": [
    {
      "name": "mpg123 maintainers"
    }
  ],
  "license": "LGPL-2.1-only",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmpg123\\Libmpg123",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install mpg123"
      ],
      "checkIfExists": [
        "brew list mpg123"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmpg123-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists mpg123"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmpg123-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists mpg123"
      ]
    },
    "alpine": {
      "install": [
        "apk add mpg123-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists mpg123"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y mpg123-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists mpg123"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y mpg123-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists mpg123"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install mpg123"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmpg123": {
      "symbol_prefix": "mpg123",
      "library_names": [
        "libmpg123.dylib",
        "libmpg123.so",
        "mpg123.dll"
      ],
      "header_names": [
        "mpg123.h"
      ],
      "version": ">=1.30.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
