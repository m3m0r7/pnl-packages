{
  "schema_version": "2026-07-01",
  "name": "libsdl/libsdl",
  "version": "2.32.10",
  "description": "PHP FFI wrapper for SDL version APIs.",
  "authors": [
    {
      "name": "SDL maintainers"
    }
  ],
  "license": "Zlib",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsdl\\Libsdl",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install sdl2 sdl2_image sdl2_ttf"
      ],
      "checkIfExists": [
        "brew list sdl2 && brew list sdl2_image && brew list sdl2_ttf"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libsdl2-dev libsdl2-image-dev libsdl2-ttf-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists sdl2 SDL2_image SDL2_ttf"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libsdl2-dev libsdl2-image-dev libsdl2-ttf-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists sdl2 SDL2_image SDL2_ttf"
      ]
    },
    "alpine": {
      "install": [
        "apk add sdl2-dev sdl2_image-dev sdl2_ttf-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists sdl2 SDL2_image SDL2_ttf"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y SDL2-devel SDL2_image-devel SDL2_ttf-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists sdl2 SDL2_image SDL2_ttf"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y SDL2-devel SDL2_image-devel SDL2_ttf-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists sdl2 SDL2_image SDL2_ttf"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install sdl2 sdl2-image sdl2-ttf"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "sdl2": {
      "symbol_prefix": "SDL",
      "library_names": [
        "libSDL2.dylib",
        "libSDL2-2.0.so",
        "SDL2.dll"
      ],
      "header_names": [
        "SDL2/SDL.h",
        "SDL2/SDL_audio.h",
        "SDL2/SDL_clipboard.h",
        "SDL2/SDL_cpuinfo.h",
        "SDL2/SDL_error.h",
        "SDL2/SDL_events.h",
        "SDL2/SDL_filesystem.h",
        "SDL2/SDL_gamecontroller.h",
        "SDL2/SDL_haptic.h",
        "SDL2/SDL_hidapi.h",
        "SDL2/SDL_hints.h",
        "SDL2/SDL_joystick.h",
        "SDL2/SDL_keyboard.h",
        "SDL2/SDL_loadso.h",
        "SDL2/SDL_locale.h",
        "SDL2/SDL_log.h",
        "SDL2/SDL_messagebox.h",
        "SDL2/SDL_misc.h",
        "SDL2/SDL_mouse.h",
        "SDL2/SDL_mutex.h",
        "SDL2/SDL_pixels.h",
        "SDL2/SDL_platform.h",
        "SDL2/SDL_power.h",
        "SDL2/SDL_render.h",
        "SDL2/SDL_rwops.h",
        "SDL2/SDL_sensor.h",
        "SDL2/SDL_shape.h",
        "SDL2/SDL_surface.h",
        "SDL2/SDL_thread.h",
        "SDL2/SDL_timer.h",
        "SDL2/SDL_touch.h",
        "SDL2/SDL_version.h",
        "SDL2/SDL_video.h",
        "SDL2/SDL_vulkan.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
