{
  "schema_version": "2026-07-01",
  "name": "libsrt/libsrt",
  "version": "1.5.4",
  "description": "PHP FFI wrapper for SRT, the Secure Reliable Transport protocol.",
  "authors": [
    {
      "name": "Libsrt maintainers"
    }
  ],
  "license": "MPL-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsrt\\Libsrt",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "srt": {
      "symbol_prefix": "srt",
      "library_names": [
        "libsrt.dylib",
        "libsrt.so",
        "srt.dll"
      ],
      "header_names": [
        "srt/srt.h"
      ],
      "version": ">=1.4.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install srt"
        ],
        "check_if_exists": [
          "brew list srt"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsrt-openssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists srt"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsrt-openssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists srt"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libsrt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists srt"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y srt-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists srt"
        ]
      }
    }
  }
}
