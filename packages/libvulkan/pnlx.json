{
  "schema_version": "2026-07-01",
  "name": "libvulkan/libvulkan",
  "version": "1.3.280",
  "description": "PHP FFI wrapper for the Vulkan loader.",
  "authors": [
    {
      "name": "Vulkan maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libvulkan\\Libvulkan",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install vulkan-loader"
      ],
      "checkIfExists": [
        "brew list vulkan-loader"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libvulkan-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists vulkan"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libvulkan-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists vulkan"
      ]
    },
    "alpine": {
      "install": [
        "apk add vulkan-loader-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists vulkan"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y vulkan-loader-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists vulkan"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y vulkan-loader-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists vulkan"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install vulkan"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libvulkan": {
      "symbol_prefix": "vk",
      "library_names": [
        "libvulkan.dylib",
        "libvulkan.so",
        "vulkan-1.dll"
      ],
      "header_names": [
        "vulkan/vulkan.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
