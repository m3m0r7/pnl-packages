{
  "schema_version": "2026-07-01",
  "name": "libvulkan/libvulkan",
  "version": "1.3.280",
  "description": "PHP FFI wrapper for the Vulkan loader.",
  "authors": [
    {
      "name": "Vulkan maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libvulkan\\Libvulkan",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libvulkan": {
      "symbol_prefix": "vk",
      "library_names": [
        "libvulkan.dylib",
        "libvulkan.so",
        "vulkan-1.dll"
      ],
      "header_names": [
        "vulkan/vulkan.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install vulkan-loader"
        ],
        "check_if_exists": [
          "brew list vulkan-loader"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libvulkan-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vulkan"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libvulkan-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vulkan"
        ]
      },
      "alpine": {
        "commands": [
          "apk add vulkan-loader-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vulkan"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y vulkan-loader-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists vulkan"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y vulkan-loader-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists vulkan"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install vulkan"
        ]
      }
    }
  }
}
