{
  "schema_version": "2026-07-01",
  "name": "libcbor/libcbor",
  "version": "0.11.0",
  "description": "PHP FFI wrapper for libcbor, a CBOR (RFC 8949) encoder and decoder.",
  "authors": [
    {
      "name": "libcbor maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcbor\\Libcbor",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-inspect.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libcbor": {
      "symbol_prefix": "cbor",
      "library_names": [
        "libcbor.dylib",
        "libcbor.so",
        "cbor.dll"
      ],
      "header_names": [
        "cbor.h"
      ],
      "version": ">=0.9.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libcbor"
        ],
        "check_if_exists": [
          "brew list libcbor"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcbor-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcbor"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcbor-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcbor"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libcbor-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcbor"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libcbor-devel"
        ],
        "check_if_exists": [
          "rpm -q libcbor-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libcbor-devel"
        ],
        "check_if_exists": [
          "rpm -q libcbor-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libcbor"
        ]
      }
    }
  }
}
