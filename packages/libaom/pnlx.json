{
  "schema_version": "2026-07-01",
  "name": "libaom/libaom",
  "version": "3.13.1",
  "description": "PHP FFI wrapper for libaom, the AV1 reference codec.",
  "authors": [
    {
      "name": "Libaom maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libaom\\Libaom",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-build-info.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "aom": {
      "symbol_prefix": "aom",
      "library_names": [
        "libaom.dylib",
        "libaom.so",
        "aom.dll"
      ],
      "header_names": [
        "aom/aom_codec.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install aom"
        ],
        "check_if_exists": [
          "brew list aom"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libaom-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists aom"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libaom-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists aom"
        ]
      },
      "alpine": {
        "commands": [
          "apk add aom-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists aom"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libaom-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists aom"
        ]
      }
    }
  }
}
