{
  "schema_version": "2026-07-01",
  "name": "libpcap/libpcap",
  "version": "1.10.4",
  "description": "PHP FFI wrapper for libpcap packet capture.",
  "authors": [
    {
      "name": "libpcap maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpcap\\Libpcap",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libpcap"
      ],
      "checkIfExists": [
        "brew list libpcap"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libpcap-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libpcap"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libpcap-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libpcap"
      ]
    },
    "alpine": {
      "install": [
        "apk add libpcap-dev"
      ],
      "checkIfExists": [
        "apk info -e libpcap-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libpcap-devel"
      ],
      "checkIfExists": [
        "rpm -q libpcap-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libpcap-devel"
      ],
      "checkIfExists": [
        "rpm -q libpcap-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libpcap"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libpcap": {
      "symbol_prefix": "pcap",
      "library_names": [
        "libpcap.dylib",
        "libpcap.so",
        "pcap.dll"
      ],
      "header_names": [
        "pcap.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
