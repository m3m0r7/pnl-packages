{
  "schema_version": "2026-07-01",
  "name": "libpcap/libpcap",
  "version": "1.10.4",
  "description": "PHP FFI wrapper for libpcap packet capture.",
  "authors": [
    {
      "name": "libpcap maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpcap\\Libpcap",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-datalink.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libpcap": {
      "symbol_prefix": "pcap",
      "library_names": [
        "libpcap.dylib",
        "libpcap.so",
        "pcap.dll"
      ],
      "header_names": [
        "pcap.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libpcap"
        ],
        "check_if_exists": [
          "brew list libpcap"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpcap-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libpcap"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpcap-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libpcap"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libpcap-dev"
        ],
        "check_if_exists": [
          "apk info -e libpcap-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libpcap-devel"
        ],
        "check_if_exists": [
          "rpm -q libpcap-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libpcap-devel"
        ],
        "check_if_exists": [
          "rpm -q libpcap-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libpcap"
        ]
      }
    }
  }
}
