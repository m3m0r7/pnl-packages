{
  "schema_version": "2026-07-01",
  "name": "libunistring/libunistring",
  "version": "1.3.0",
  "description": "PHP FFI wrapper for GNU libunistring, Unicode string functions.",
  "authors": [
    {
      "name": "libunistring maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libunistring\\Libunistring",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-char-class.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "unistring": {
      "symbol_prefix": "uc_",
      "library_names": [
        "libunistring.dylib",
        "libunistring.so",
        "unistring.dll"
      ],
      "header_names": [
        "unictype.h"
      ],
      "version": ">=0.9.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libunistring"
        ],
        "check_if_exists": [
          "brew list libunistring"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libunistring-dev"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libunistring-dev"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libunistring-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libunistring-devel"
        ]
      }
    }
  }
}
