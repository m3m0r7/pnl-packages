{
  "schema_version": "2026-07-01",
  "name": "libmodbus/libmodbus",
  "version": "3.1.10",
  "description": "PHP FFI wrapper for libmodbus.",
  "authors": [
    {
      "name": "libmodbus maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmodbus\\Libmodbus",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libmodbus"
      ],
      "checkIfExists": [
        "brew list libmodbus"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmodbus-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmodbus"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmodbus-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmodbus"
      ]
    },
    "alpine": {
      "install": [
        "apk add libmodbus-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libmodbus"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libmodbus-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libmodbus"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libmodbus-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libmodbus"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmodbus": {
      "symbol_prefix": "modbus",
      "library_names": [
        "libmodbus.dylib",
        "libmodbus.so",
        "modbus.dll"
      ],
      "header_names": [
        "modbus/modbus.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
