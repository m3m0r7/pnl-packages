{
  "schema_version": "2026-07-01",
  "name": "libmodbus/libmodbus",
  "version": "3.1.10",
  "description": "PHP FFI wrapper for libmodbus.",
  "authors": [
    {
      "name": "libmodbus maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmodbus\\Libmodbus",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strerror.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmodbus": {
      "symbol_prefix": "modbus",
      "library_names": [
        "libmodbus.dylib",
        "libmodbus.so",
        "modbus.dll"
      ],
      "header_names": [
        "modbus/modbus.h"
      ],
      "version": ">=3.0.0 & <4.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libmodbus"
        ],
        "check_if_exists": [
          "brew list libmodbus"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmodbus-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmodbus"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmodbus-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmodbus"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libmodbus-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmodbus"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libmodbus-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmodbus"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libmodbus-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libmodbus"
        ]
      }
    }
  }
}
