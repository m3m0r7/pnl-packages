{
  "schema_version": "2026-07-01",
  "name": "libxxhash/libxxhash",
  "version": "0.8.2",
  "description": "PHP FFI wrapper for the xxHash hashing library.",
  "authors": [
    {
      "name": "xxHash maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libxxhash\\Libxxhash",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install xxhash"
      ],
      "checkIfExists": [
        "brew list xxhash"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libxxhash-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxxhash"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libxxhash-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxxhash"
      ]
    },
    "alpine": {
      "install": [
        "apk add xxhash-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxxhash"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y xxhash-devel"
      ],
      "checkIfExists": [
        "rpm -q xxhash-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y xxhash-devel"
      ],
      "checkIfExists": [
        "rpm -q xxhash-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libxxhash": {
      "symbol_prefix": "XXH",
      "library_names": [
        "libxxhash.dylib",
        "libxxhash.so",
        "xxhash.dll"
      ],
      "header_names": [
        "xxhash.h"
      ],
      "version": ">=0.8.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
