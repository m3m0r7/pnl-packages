{
  "schema_version": "2026-07-01",
  "name": "libxxhash/libxxhash",
  "version": "0.8.2",
  "description": "PHP FFI wrapper for the xxHash hashing library.",
  "authors": [
    {
      "name": "xxHash maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libxxhash\\Libxxhash",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-oneshot.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libxxhash": {
      "symbol_prefix": "XXH",
      "library_names": [
        "libxxhash.dylib",
        "libxxhash.so",
        "xxhash.dll"
      ],
      "header_names": [
        "xxhash.h"
      ],
      "version": ">=0.8.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install xxhash"
        ],
        "check_if_exists": [
          "brew list xxhash"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libxxhash-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxxhash"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libxxhash-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxxhash"
        ]
      },
      "alpine": {
        "commands": [
          "apk add xxhash-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxxhash"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y xxhash-devel"
        ],
        "check_if_exists": [
          "rpm -q xxhash-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y xxhash-devel"
        ],
        "check_if_exists": [
          "rpm -q xxhash-devel"
        ]
      }
    }
  }
}
