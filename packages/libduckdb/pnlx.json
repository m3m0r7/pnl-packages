{
  "schema_version": "2026-07-01",
  "name": "libduckdb/libduckdb",
  "version": "0.10.2",
  "description": "PHP FFI wrapper for the DuckDB analytical database.",
  "authors": [
    {
      "name": "DuckDB maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libduckdb\\Libduckdb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-values.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "duckdb": {
      "symbol_prefix": "duckdb",
      "library_names": [
        "libduckdb.dylib",
        "libduckdb.so",
        "duckdb.dll"
      ],
      "header_names": [
        "duckdb.h"
      ],
      "version": ">=0.9.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install duckdb"
        ],
        "check_if_exists": [
          "brew list duckdb"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libduckdb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libduckdb.so"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libduckdb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libduckdb.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add duckdb-dev"
        ],
        "check_if_exists": [
          "apk info -e duckdb-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y duckdb-devel"
        ],
        "check_if_exists": [
          "rpm -q duckdb-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y duckdb-devel"
        ],
        "check_if_exists": [
          "rpm -q duckdb-devel"
        ]
      }
    }
  }
}
