{
  "schema_version": "2026-07-01",
  "name": "libduckdb/libduckdb",
  "version": "0.10.2",
  "description": "PHP FFI wrapper for the DuckDB analytical database.",
  "authors": [
    {
      "name": "DuckDB maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libduckdb\\Libduckdb",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install duckdb"
      ],
      "checkIfExists": [
        "brew list duckdb"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libduckdb-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libduckdb.so"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libduckdb-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libduckdb.so"
      ]
    },
    "alpine": {
      "install": [
        "apk add duckdb-dev"
      ],
      "checkIfExists": [
        "apk info -e duckdb-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y duckdb-devel"
      ],
      "checkIfExists": [
        "rpm -q duckdb-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y duckdb-devel"
      ],
      "checkIfExists": [
        "rpm -q duckdb-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "duckdb": {
      "symbol_prefix": "duckdb",
      "library_names": [
        "libduckdb.dylib",
        "libduckdb.so",
        "duckdb.dll"
      ],
      "header_names": [
        "duckdb.h"
      ],
      "version": ">=0.9.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
