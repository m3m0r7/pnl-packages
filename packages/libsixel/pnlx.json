{
  "schema_version": "2026-07-01",
  "name": "libsixel/libsixel",
  "version": "1.10.3",
  "description": "PHP FFI wrapper for libsixel terminal SIXEL graphics.",
  "authors": [
    {
      "name": "libsixel maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsixel\\Libsixel",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-message.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libsixel": {
      "symbol_prefix": "sixel",
      "library_names": [
        "libsixel.dylib",
        "libsixel.so",
        "sixel.dll"
      ],
      "header_names": [
        "sixel.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libsixel"
        ],
        "check_if_exists": [
          "brew list libsixel"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsixel-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsixel"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsixel-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsixel"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libsixel-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libsixel"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libsixel-devel"
        ],
        "check_if_exists": [
          "rpm -q libsixel-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libsixel-devel"
        ],
        "check_if_exists": [
          "rpm -q libsixel-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libsixel"
        ]
      }
    }
  }
}
