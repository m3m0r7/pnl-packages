{
  "schema_version": "2026-07-01",
  "name": "libsixel/libsixel",
  "version": "1.10.3",
  "description": "PHP FFI wrapper for libsixel terminal SIXEL graphics.",
  "authors": [
    {
      "name": "libsixel maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsixel\\Libsixel",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libsixel"
      ],
      "checkIfExists": [
        "brew list libsixel"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libsixel-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libsixel"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libsixel-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libsixel"
      ]
    },
    "alpine": {
      "install": [
        "apk add libsixel-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libsixel"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libsixel-devel"
      ],
      "checkIfExists": [
        "rpm -q libsixel-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libsixel-devel"
      ],
      "checkIfExists": [
        "rpm -q libsixel-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libsixel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libsixel": {
      "symbol_prefix": "sixel",
      "library_names": [
        "libsixel.dylib",
        "libsixel.so",
        "sixel.dll"
      ],
      "header_names": [
        "sixel.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
