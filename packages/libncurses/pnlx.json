{
  "schema_version": "2026-07-01",
  "name": "libncurses/libncurses",
  "version": "6.4",
  "description": "PHP FFI wrapper for the ncurses terminal UI library.",
  "authors": [
    {
      "name": "ncurses maintainers"
    }
  ],
  "license": "X11",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libncurses\\Libncurses",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-keyname.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "ncurses": {
      "library_names": [
        "libncurses.dylib",
        "libncurses.so",
        "ncurses.dll"
      ],
      "header_names": [
        "curses.h",
        "ncurses.h"
      ],
      "version": ">=6.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ncurses"
        ],
        "check_if_exists": [
          "brew list ncurses"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libncurses-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libncurses"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libncurses-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libncurses"
        ]
      },
      "alpine": {
        "commands": [
          "apk add ncurses-dev"
        ],
        "check_if_exists": [
          "apk info -e ncurses-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y ncurses-devel"
        ],
        "check_if_exists": [
          "rpm -q ncurses-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y ncurses-devel"
        ],
        "check_if_exists": [
          "rpm -q ncurses-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install ncurses"
        ]
      }
    }
  }
}
