{
  "schema_version": "2026-07-01",
  "name": "libncurses/libncurses",
  "version": "6.4",
  "description": "PHP FFI wrapper for the ncurses terminal UI library.",
  "authors": [
    {
      "name": "ncurses maintainers"
    }
  ],
  "license": "X11",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libncurses\\Libncurses",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install ncurses"
      ],
      "checkIfExists": [
        "brew list ncurses"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libncurses-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libncurses"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libncurses-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libncurses"
      ]
    },
    "alpine": {
      "install": [
        "apk add ncurses-dev"
      ],
      "checkIfExists": [
        "apk info -e ncurses-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y ncurses-devel"
      ],
      "checkIfExists": [
        "rpm -q ncurses-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y ncurses-devel"
      ],
      "checkIfExists": [
        "rpm -q ncurses-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install ncurses"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "ncurses": {
      "library_names": [
        "libncurses.dylib",
        "libncurses.so",
        "ncurses.dll"
      ],
      "header_names": [
        "curses.h",
        "ncurses.h"
      ],
      "version": ">=6.0.0 & <7.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
