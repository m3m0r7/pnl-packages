{
  "schema_version": "2026-07-01",
  "name": "libpixman/libpixman",
  "version": "0.43.4",
  "description": "PHP FFI wrapper for the Pixman pixel manipulation library.",
  "authors": [
    {
      "name": "Pixman maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpixman\\Libpixman",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-format-support.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libpixman-1": {
      "symbol_prefix": "pixman",
      "library_names": [
        "libpixman-1.dylib",
        "libpixman-1.so",
        "pixman-1.dll"
      ],
      "header_names": [
        "pixman.h",
        "pixman-1/pixman.h"
      ],
      "version": ">=0.40.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install pixman"
        ],
        "check_if_exists": [
          "brew list pixman"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libpixman-1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists pixman-1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libpixman-1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists pixman-1"
        ]
      },
      "alpine": {
        "commands": [
          "apk add pixman-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists pixman-1"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y pixman-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists pixman-1"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y pixman-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists pixman-1"
        ]
      }
    }
  }
}
