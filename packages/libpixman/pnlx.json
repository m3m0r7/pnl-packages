{
  "schema_version": "2026-07-01",
  "name": "libpixman/libpixman",
  "version": "0.43.4",
  "description": "PHP FFI wrapper for the Pixman pixel manipulation library.",
  "authors": [
    {
      "name": "Pixman maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libpixman\\Libpixman",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install pixman"
      ],
      "checkIfExists": [
        "brew list pixman"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libpixman-1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists pixman-1"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libpixman-1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists pixman-1"
      ]
    },
    "alpine": {
      "install": [
        "apk add pixman-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists pixman-1"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y pixman-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists pixman-1"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y pixman-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists pixman-1"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libpixman-1": {
      "symbol_prefix": "pixman",
      "library_names": [
        "libpixman-1.dylib",
        "libpixman-1.so",
        "pixman-1.dll"
      ],
      "header_names": [
        "pixman.h",
        "pixman-1/pixman.h"
      ],
      "version": ">=0.40.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
