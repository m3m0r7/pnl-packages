{
  "schema_version": "2026-07-01",
  "name": "libmagic/libmagic",
  "version": "5.45",
  "description": "PHP FFI wrapper for libmagic file type detection.",
  "authors": [
    {
      "name": "libmagic maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmagic\\Libmagic",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmagic": {
      "symbol_prefix": "magic",
      "library_names": [
        "libmagic.dylib",
        "libmagic.so",
        "magic.dll"
      ],
      "header_names": [
        "magic.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libmagic"
        ],
        "check_if_exists": [
          "brew list libmagic"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmagic-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libmagic"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmagic-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libmagic"
        ]
      },
      "alpine": {
        "commands": [
          "apk add file-dev"
        ],
        "check_if_exists": [
          "apk info -e file-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y file-devel"
        ],
        "check_if_exists": [
          "rpm -q file-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y file-devel"
        ],
        "check_if_exists": [
          "rpm -q file-devel"
        ]
      }
    }
  }
}
