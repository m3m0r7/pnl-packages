{
  "schema_version": "2026-07-01",
  "name": "libmagic/libmagic",
  "version": "5.45",
  "description": "PHP FFI wrapper for libmagic file type detection.",
  "authors": [
    {
      "name": "libmagic maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmagic\\Libmagic",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libmagic"
      ],
      "checkIfExists": [
        "brew list libmagic"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libmagic-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libmagic"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libmagic-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libmagic"
      ]
    },
    "alpine": {
      "install": [
        "apk add file-dev"
      ],
      "checkIfExists": [
        "apk info -e file-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y file-devel"
      ],
      "checkIfExists": [
        "rpm -q file-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y file-devel"
      ],
      "checkIfExists": [
        "rpm -q file-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libmagic": {
      "symbol_prefix": "magic",
      "library_names": [
        "libmagic.dylib",
        "libmagic.so",
        "magic.dll"
      ],
      "header_names": [
        "magic.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
