{
  "schema_version": "2026-07-01",
  "name": "libgcrypt/libgcrypt",
  "version": "1.10.3",
  "description": "PHP FFI wrapper for Libgcrypt cryptography.",
  "authors": [
    {
      "name": "Libgcrypt maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgcrypt\\Libgcrypt",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-digest-algorithms.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libgcrypt": {
      "symbol_prefix": "gcry",
      "library_names": [
        "libgcrypt.dylib",
        "libgcrypt.so",
        "gcrypt.dll"
      ],
      "header_names": [
        "gcrypt.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libgcrypt"
        ],
        "check_if_exists": [
          "brew list libgcrypt"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgcrypt20-dev"
        ],
        "check_if_exists": [
          "libgcrypt-config --version"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgcrypt20-dev"
        ],
        "check_if_exists": [
          "libgcrypt-config --version"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libgcrypt-dev"
        ],
        "check_if_exists": [
          "apk info -e libgcrypt-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libgcrypt-devel"
        ],
        "check_if_exists": [
          "rpm -q libgcrypt-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libgcrypt-devel"
        ],
        "check_if_exists": [
          "rpm -q libgcrypt-devel"
        ]
      }
    }
  }
}
