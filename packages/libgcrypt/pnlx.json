{
  "schema_version": "2026-07-01",
  "name": "libgcrypt/libgcrypt",
  "version": "1.10.3",
  "description": "PHP FFI wrapper for Libgcrypt cryptography.",
  "authors": [
    {
      "name": "Libgcrypt maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgcrypt\\Libgcrypt",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libgcrypt"
      ],
      "checkIfExists": [
        "brew list libgcrypt"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libgcrypt20-dev"
      ],
      "checkIfExists": [
        "libgcrypt-config --version"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libgcrypt20-dev"
      ],
      "checkIfExists": [
        "libgcrypt-config --version"
      ]
    },
    "alpine": {
      "install": [
        "apk add libgcrypt-dev"
      ],
      "checkIfExists": [
        "apk info -e libgcrypt-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libgcrypt-devel"
      ],
      "checkIfExists": [
        "rpm -q libgcrypt-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libgcrypt-devel"
      ],
      "checkIfExists": [
        "rpm -q libgcrypt-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libgcrypt": {
      "symbol_prefix": "gcry",
      "library_names": [
        "libgcrypt.dylib",
        "libgcrypt.so",
        "gcrypt.dll"
      ],
      "header_names": [
        "gcrypt.h"
      ],
      "version": ">=1.8.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
