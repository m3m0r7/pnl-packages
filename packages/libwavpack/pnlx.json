{
  "schema_version": "2026-07-01",
  "name": "libwavpack/libwavpack",
  "version": "5.7.0",
  "description": "PHP FFI wrapper for the WavPack hybrid lossless audio codec.",
  "authors": [
    {
      "name": "WavPack maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libwavpack\\Libwavpack",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-library-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "wavpack": {
      "symbol_prefix": "Wavpack",
      "library_names": [
        "libwavpack.dylib",
        "libwavpack.so",
        "wavpack.dll"
      ],
      "header_names": [
        "wavpack/wavpack.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install wavpack"
        ],
        "check_if_exists": [
          "brew list wavpack"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libwavpack-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists wavpack"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libwavpack-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists wavpack"
        ]
      },
      "alpine": {
        "commands": [
          "apk add wavpack-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists wavpack"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y wavpack-devel"
        ],
        "check_if_exists": [
          "rpm -q wavpack-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y wavpack-devel"
        ],
        "check_if_exists": [
          "rpm -q wavpack-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install wavpack"
        ]
      }
    }
  }
}
