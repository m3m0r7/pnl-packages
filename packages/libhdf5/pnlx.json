{
  "schema_version": "2026-07-01",
  "name": "libhdf5/libhdf5",
  "version": "1.14.0",
  "description": "PHP FFI wrapper for HDF5, the hierarchical scientific data library.",
  "authors": [
    {
      "name": "Libhdf5 maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libhdf5\\Libhdf5",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-library-lifecycle.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "hdf5": {
      "symbol_prefix": "H5",
      "library_names": [
        "libhdf5.dylib",
        "libhdf5.so",
        "hdf5.dll"
      ],
      "header_names": [
        "hdf5.h"
      ],
      "version": ">=1.10.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install hdf5"
        ],
        "check_if_exists": [
          "brew list hdf5"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libhdf5-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hdf5"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libhdf5-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hdf5"
        ]
      },
      "alpine": {
        "commands": [
          "apk add hdf5-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hdf5"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y hdf5-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists hdf5"
        ]
      }
    }
  }
}
