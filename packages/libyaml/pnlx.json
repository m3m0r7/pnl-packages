{
  "schema_version": "2026-07-01",
  "name": "libyaml/libyaml",
  "version": "0.2.5",
  "description": "PHP FFI wrapper for libyaml YAML parser.",
  "authors": [
    {
      "name": "libyaml maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libyaml\\Libyaml",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "yaml": {
      "symbol_prefix": "yaml",
      "library_names": [
        "libyaml.dylib",
        "libyaml-0.so",
        "yaml.dll"
      ],
      "header_names": [
        "yaml.h"
      ],
      "version": ">=0.2.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libyaml"
        ],
        "check_if_exists": [
          "brew list libyaml"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libyaml-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists yaml-0.1"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libyaml-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists yaml-0.1"
        ]
      },
      "alpine": {
        "commands": [
          "apk add yaml-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists yaml-0.1"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libyaml-devel"
        ],
        "check_if_exists": [
          "rpm -q libyaml-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libyaml-devel"
        ],
        "check_if_exists": [
          "rpm -q libyaml-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libyaml"
        ]
      }
    }
  }
}
