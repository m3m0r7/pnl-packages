{
  "schema_version": "2026-07-01",
  "name": "libfreetype/libfreetype",
  "version": "2.13.2",
  "description": "PHP FFI wrapper for FreeType font rendering.",
  "authors": [
    {
      "name": "FreeType maintainers"
    }
  ],
  "license": "FTL",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libfreetype\\Libfreetype",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-fixed-point.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "freetype2": {
      "symbol_prefix": "FT",
      "library_names": [
        "libfreetype.dylib",
        "libfreetype.so",
        "freetype.dll"
      ],
      "header_names": [
        "ft2build.h",
        "freetype/freetype.h"
      ],
      "version": ">=2.10.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install freetype"
        ],
        "check_if_exists": [
          "brew list freetype"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libfreetype-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists freetype2"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libfreetype-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists freetype2"
        ]
      },
      "alpine": {
        "commands": [
          "apk add freetype-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists freetype2"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y freetype-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists freetype2"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y freetype-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists freetype2"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install freetype"
        ]
      }
    }
  }
}
