{
  "schema_version": "2026-07-01",
  "name": "libmongoc/libmongoc",
  "version": "1.27.0",
  "description": "PHP FFI wrapper for the MongoDB C driver (libmongoc).",
  "authors": [
    {
      "name": "MongoDB / mongo-c-driver maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmongoc\\Libmongoc",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libmongoc-1.0": {
      "symbol_prefix": "mongoc",
      "library_names": [
        "libmongoc-1.0.dylib",
        "libmongoc-1.0.so",
        "mongoc-1.0.dll"
      ],
      "header_names": [
        "mongoc/mongoc.h"
      ],
      "version": ">=1.20.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mongo-c-driver"
        ],
        "check_if_exists": [
          "brew list mongo-c-driver"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmongoc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmongoc-1.0"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmongoc-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmongoc-1.0"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mongo-c-driver-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmongoc-1.0"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mongo-c-driver-devel"
        ],
        "check_if_exists": [
          "rpm -q mongo-c-driver-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y mongo-c-driver-devel"
        ],
        "check_if_exists": [
          "rpm -q mongo-c-driver-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install mongo-c-driver"
        ]
      }
    }
  }
}
