{
  "schema_version": "2026-07-01",
  "name": "libcares/libcares",
  "version": "1.28.1",
  "description": "PHP FFI wrapper for the c-ares async DNS library.",
  "authors": [
    {
      "name": "c-ares maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcares\\Libcares",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strerror.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libcares": {
      "symbol_prefix": "ares",
      "library_names": [
        "libcares.dylib",
        "libcares.so",
        "cares.dll"
      ],
      "header_names": [
        "ares.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install c-ares"
        ],
        "check_if_exists": [
          "brew list c-ares"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libc-ares-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcares"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libc-ares-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcares"
        ]
      },
      "alpine": {
        "commands": [
          "apk add c-ares-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcares"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y c-ares-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libcares"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y c-ares-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libcares"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install c-ares"
        ]
      }
    }
  }
}
