{
  "schema_version": "2026-07-01",
  "name": "libjansson/libjansson",
  "version": "2.14",
  "description": "PHP FFI wrapper for the Jansson JSON library.",
  "authors": [
    {
      "name": "Jansson maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libjansson\\Libjansson",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install jansson"
      ],
      "checkIfExists": [
        "brew list jansson"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libjansson-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists jansson"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libjansson-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists jansson"
      ]
    },
    "alpine": {
      "install": [
        "apk add jansson-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists jansson"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y jansson-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists jansson"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y jansson-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists jansson"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install jansson"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libjansson": {
      "symbol_prefix": "json",
      "library_names": [
        "libjansson.dylib",
        "libjansson.so",
        "jansson.dll"
      ],
      "header_names": [
        "jansson.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
