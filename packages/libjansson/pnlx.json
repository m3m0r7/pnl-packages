{
  "schema_version": "2026-07-01",
  "name": "libjansson/libjansson",
  "version": "2.14",
  "description": "PHP FFI wrapper for the Jansson JSON library.",
  "authors": [
    {
      "name": "Jansson maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libjansson\\Libjansson",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-values.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libjansson": {
      "symbol_prefix": "json",
      "library_names": [
        "libjansson.dylib",
        "libjansson.so",
        "jansson.dll"
      ],
      "header_names": [
        "jansson.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install jansson"
        ],
        "check_if_exists": [
          "brew list jansson"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libjansson-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists jansson"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libjansson-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists jansson"
        ]
      },
      "alpine": {
        "commands": [
          "apk add jansson-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists jansson"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y jansson-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists jansson"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y jansson-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists jansson"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install jansson"
        ]
      }
    }
  }
}
