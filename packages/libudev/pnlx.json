{
  "schema_version": "2026-07-01",
  "name": "libudev/libudev",
  "version": "255.0.0",
  "description": "PHP FFI wrapper for libudev Linux device enumeration and monitoring.",
  "authors": [
    {
      "name": "systemd / udev maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libudev\\Libudev",
  "examples": [
    "EXAMPLES.md"
  ],
  "platforms": [
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "libudev": {
      "symbol_prefix": "udev",
      "library_names": [
        "libudev.so"
      ],
      "header_names": [
        "libudev.h"
      ],
      "version": ">=240.0.0 & <260.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libudev-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libudev"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libudev-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libudev"
        ]
      },
      "alpine": {
        "commands": [
          "apk add eudev-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libudev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y systemd-devel"
        ],
        "check_if_exists": [
          "rpm -q systemd-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y systemd-devel"
        ],
        "check_if_exists": [
          "rpm -q systemd-devel"
        ]
      }
    }
  }
}
