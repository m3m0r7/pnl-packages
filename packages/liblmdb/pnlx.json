{
  "schema_version": "2026-07-01",
  "name": "liblmdb/liblmdb",
  "version": "0.9.31",
  "description": "PHP FFI wrapper for the LMDB key-value store.",
  "authors": [
    {
      "name": "LMDB maintainers"
    }
  ],
  "license": "OLDAP-2.8",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Liblmdb\\Liblmdb",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strerror.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "liblmdb": {
      "symbol_prefix": "mdb",
      "library_names": [
        "liblmdb.dylib",
        "liblmdb.so",
        "lmdb.dll"
      ],
      "header_names": [
        "lmdb.h"
      ],
      "version": ">=0.9.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install lmdb"
        ],
        "check_if_exists": [
          "brew list lmdb"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y liblmdb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q liblmdb"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y liblmdb-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q liblmdb"
        ]
      },
      "alpine": {
        "commands": [
          "apk add lmdb-dev"
        ],
        "check_if_exists": [
          "apk info -e lmdb-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y lmdb-devel"
        ],
        "check_if_exists": [
          "rpm -q lmdb-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y lmdb-devel"
        ],
        "check_if_exists": [
          "rpm -q lmdb-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install lmdb"
        ]
      }
    }
  }
}
