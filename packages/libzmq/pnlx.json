{
  "schema_version": "2026-07-01",
  "name": "libzmq/libzmq",
  "version": "4.3.5",
  "description": "PHP FFI wrapper for ZeroMQ messaging.",
  "authors": [
    {
      "name": "ZeroMQ maintainers"
    }
  ],
  "license": "MPL-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzmq\\Libzmq",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-diagnostics.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libzmq": {
      "symbol_prefix": "zmq",
      "library_names": [
        "libzmq.dylib",
        "libzmq.so",
        "libzmq.dll"
      ],
      "header_names": [
        "zmq.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install zeromq"
        ],
        "check_if_exists": [
          "brew list zeromq"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libzmq3-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzmq"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libzmq3-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzmq"
        ]
      },
      "alpine": {
        "commands": [
          "apk add zeromq-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libzmq"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y zeromq-devel"
        ],
        "check_if_exists": [
          "rpm -q zeromq-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y zeromq-devel"
        ],
        "check_if_exists": [
          "rpm -q zeromq-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install zeromq"
        ]
      }
    }
  }
}
