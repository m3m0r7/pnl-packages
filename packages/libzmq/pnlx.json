{
  "schema_version": "2026-07-01",
  "name": "libzmq/libzmq",
  "version": "4.3.5",
  "description": "PHP FFI wrapper for ZeroMQ messaging.",
  "authors": [
    {
      "name": "ZeroMQ maintainers"
    }
  ],
  "license": "MPL-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libzmq\\Libzmq",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install zeromq"
      ],
      "checkIfExists": [
        "brew list zeromq"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libzmq3-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzmq"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libzmq3-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzmq"
      ]
    },
    "alpine": {
      "install": [
        "apk add zeromq-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libzmq"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y zeromq-devel"
      ],
      "checkIfExists": [
        "rpm -q zeromq-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y zeromq-devel"
      ],
      "checkIfExists": [
        "rpm -q zeromq-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install zeromq"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libzmq": {
      "symbol_prefix": "zmq",
      "library_names": [
        "libzmq.dylib",
        "libzmq.so",
        "libzmq.dll"
      ],
      "header_names": [
        "zmq.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
