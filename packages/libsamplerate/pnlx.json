{
  "schema_version": "2026-07-01",
  "name": "libsamplerate/libsamplerate",
  "version": "0.2.2",
  "description": "PHP FFI wrapper for libsamplerate sample-rate conversion.",
  "authors": [
    {
      "name": "libsamplerate maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsamplerate\\Libsamplerate",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-converter-info.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libsamplerate": {
      "symbol_prefix": "src",
      "library_names": [
        "libsamplerate.dylib",
        "libsamplerate.so",
        "samplerate.dll"
      ],
      "header_names": [
        "samplerate.h"
      ],
      "version": ">=0.2.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libsamplerate"
        ],
        "check_if_exists": [
          "brew list libsamplerate"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libsamplerate0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists samplerate"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libsamplerate0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists samplerate"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libsamplerate-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists samplerate"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libsamplerate-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists samplerate"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libsamplerate-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists samplerate"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libsamplerate"
        ]
      }
    }
  }
}
