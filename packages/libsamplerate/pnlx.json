{
  "schema_version": "2026-07-01",
  "name": "libsamplerate/libsamplerate",
  "version": "0.2.2",
  "description": "PHP FFI wrapper for libsamplerate sample-rate conversion.",
  "authors": [
    {
      "name": "libsamplerate maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libsamplerate\\Libsamplerate",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libsamplerate"
      ],
      "checkIfExists": [
        "brew list libsamplerate"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libsamplerate0-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists samplerate"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libsamplerate0-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists samplerate"
      ]
    },
    "alpine": {
      "install": [
        "apk add libsamplerate-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists samplerate"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libsamplerate-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists samplerate"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libsamplerate-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists samplerate"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libsamplerate"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libsamplerate": {
      "symbol_prefix": "src",
      "library_names": [
        "libsamplerate.dylib",
        "libsamplerate.so",
        "samplerate.dll"
      ],
      "header_names": [
        "samplerate.h"
      ],
      "version": ">=0.2.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
