{
  "schema_version": "2026-07-01",
  "name": "libavutil/libavutil",
  "version": "59.8.100",
  "description": "PHP FFI wrapper for FFmpeg libavutil.",
  "authors": [
    {
      "name": "FFmpeg libavutil maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libavutil\\Libavutil",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install ffmpeg"
      ],
      "checkIfExists": [
        "brew list ffmpeg"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libavutil-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libavutil"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libavutil-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libavutil"
      ]
    },
    "alpine": {
      "install": [
        "apk add ffmpeg-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libavutil"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y ffmpeg-free-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libavutil"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y ffmpeg-free-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libavutil"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install ffmpeg"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libavutil": {
      "symbol_prefix": "av",
      "library_names": [
        "libavutil.dylib",
        "libavutil.so",
        "avutil.dll"
      ],
      "header_names": [
        "libavutil/avutil.h"
      ],
      "version": ">=56.0.0 & <60.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
