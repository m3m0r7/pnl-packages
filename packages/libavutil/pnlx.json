{
  "schema_version": "2026-07-01",
  "name": "libavutil/libavutil",
  "version": "59.8.100",
  "description": "PHP FFI wrapper for FFmpeg libavutil.",
  "authors": [
    {
      "name": "FFmpeg libavutil maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libavutil\\Libavutil",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-build-info.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libavutil": {
      "symbol_prefix": "av",
      "library_names": [
        "libavutil.dylib",
        "libavutil.so",
        "avutil.dll"
      ],
      "header_names": [
        "libavutil/avutil.h"
      ],
      "version": ">=56.0.0 & <60.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install ffmpeg"
        ],
        "check_if_exists": [
          "brew list ffmpeg"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libavutil-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavutil"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libavutil-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavutil"
        ]
      },
      "alpine": {
        "commands": [
          "apk add ffmpeg-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libavutil"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavutil"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y ffmpeg-free-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libavutil"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install ffmpeg"
        ]
      }
    }
  }
}
