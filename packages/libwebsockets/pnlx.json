{
  "schema_version": "2026-07-01",
  "name": "libwebsockets/libwebsockets",
  "version": "4.3.3",
  "description": "PHP FFI wrapper for libwebsockets.",
  "authors": [
    {
      "name": "libwebsockets maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libwebsockets\\Libwebsockets",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-lookups.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libwebsockets": {
      "symbol_prefix": "lws",
      "library_names": [
        "libwebsockets.dylib",
        "libwebsockets.so",
        "websockets.dll"
      ],
      "header_names": [
        "libwebsockets.h"
      ],
      "version": ">=4.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libwebsockets"
        ],
        "check_if_exists": [
          "brew list libwebsockets"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libwebsockets-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebsockets"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libwebsockets-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebsockets"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libwebsockets-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebsockets"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libwebsockets-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebsockets"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libwebsockets-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libwebsockets"
        ]
      }
    }
  }
}
