{
  "schema_version": "2026-07-01",
  "name": "libyajl/libyajl",
  "version": "2.1.0",
  "description": "PHP FFI wrapper for YAJL, a streaming JSON parser and generator.",
  "authors": [
    {
      "name": "YAJL maintainers"
    }
  ],
  "license": "ISC",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libyajl\\Libyajl",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-status.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "yajl": {
      "symbol_prefix": "yajl",
      "library_names": [
        "libyajl.dylib",
        "libyajl.so",
        "yajl.dll"
      ],
      "header_names": [
        "yajl/yajl_parse.h",
        "yajl/yajl_gen.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install yajl"
        ],
        "check_if_exists": [
          "brew list yajl"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libyajl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists yajl"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libyajl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists yajl"
        ]
      },
      "alpine": {
        "commands": [
          "apk add yajl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists yajl"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y yajl-devel"
        ],
        "check_if_exists": [
          "rpm -q yajl-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y yajl-devel"
        ],
        "check_if_exists": [
          "rpm -q yajl-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install yajl"
        ]
      }
    }
  }
}
