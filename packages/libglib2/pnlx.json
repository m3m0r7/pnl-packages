{
  "schema_version": "2026-07-01",
  "name": "libglib2/libglib2",
  "version": "2.80.0",
  "description": "PHP FFI wrapper for GLib core utilities and data structures.",
  "authors": [
    {
      "name": "GNOME / GLib maintainers"
    }
  ],
  "license": "LGPL-2.1-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libglib2\\Libglib2",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-strings.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "glib-2.0": {
      "symbol_prefix": "g",
      "library_names": [
        "libglib-2.0.dylib",
        "libglib-2.0.so",
        "glib-2.0-0.dll"
      ],
      "header_names": [
        "glib.h"
      ],
      "version": ">=2.50.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install glib"
        ],
        "check_if_exists": [
          "brew list glib"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libglib2.0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists glib-2.0"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libglib2.0-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists glib-2.0"
        ]
      },
      "alpine": {
        "commands": [
          "apk add glib-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists glib-2.0"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y glib2-devel"
        ],
        "check_if_exists": [
          "rpm -q glib2-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y glib2-devel"
        ],
        "check_if_exists": [
          "rpm -q glib2-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install glib"
        ]
      }
    }
  }
}
