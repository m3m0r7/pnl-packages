{
  "schema_version": "2026-07-01",
  "name": "libbrotli/libbrotli",
  "version": "1.1.0",
  "description": "PHP FFI wrapper for Brotli compression.",
  "authors": [
    {
      "name": "Brotli maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libbrotli\\Libbrotli",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-decoder-info.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libbrotlidec": {
      "symbol_prefix": "Brotli",
      "library_names": [
        "libbrotlidec.dylib",
        "libbrotlidec.so",
        "brotlidec.dll"
      ],
      "header_names": [
        "brotli/decode.h",
        "brotli/encode.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {
    "*": [
      {
        "library_names": [
          "libbrotlienc.dylib",
          "libbrotlienc.so",
          "brotlienc.dll"
        ]
      }
    ]
  },
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install brotli"
        ],
        "check_if_exists": [
          "brew list brotli"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libbrotli-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libbrotlidec"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libbrotli-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libbrotlidec"
        ]
      },
      "alpine": {
        "commands": [
          "apk add brotli-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libbrotlidec"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y brotli-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libbrotlidec"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y brotli-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libbrotlidec"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install brotli"
        ]
      }
    }
  }
}
