{
  "schema_version": "2026-07-01",
  "name": "libuv/libuv",
  "version": "1.48.0",
  "description": "PHP FFI wrapper for libuv async I/O.",
  "authors": [
    {
      "name": "libuv maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libuv\\Libuv",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libuv"
      ],
      "checkIfExists": [
        "brew list libuv"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libuv1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libuv"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libuv1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libuv"
      ]
    },
    "alpine": {
      "install": [
        "apk add libuv-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libuv"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libuv-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libuv"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libuv-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libuv"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libuv"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libuv": {
      "symbol_prefix": "uv",
      "library_names": [
        "libuv.dylib",
        "libuv.so",
        "libuv.dll"
      ],
      "header_names": [
        "uv.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
