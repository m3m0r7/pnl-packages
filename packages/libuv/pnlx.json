{
  "schema_version": "2026-07-01",
  "name": "libuv/libuv",
  "version": "1.48.0",
  "description": "PHP FFI wrapper for libuv async I/O.",
  "authors": [
    {
      "name": "libuv maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libuv\\Libuv",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-errors.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libuv": {
      "symbol_prefix": "uv",
      "library_names": [
        "libuv.dylib",
        "libuv.so",
        "libuv.dll"
      ],
      "header_names": [
        "uv.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libuv"
        ],
        "check_if_exists": [
          "brew list libuv"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libuv1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libuv"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libuv1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libuv"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libuv-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libuv"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libuv-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libuv"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libuv-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libuv"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libuv"
        ]
      }
    }
  }
}
