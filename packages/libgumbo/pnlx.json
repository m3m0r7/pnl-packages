{
  "schema_version": "2026-07-01",
  "name": "libgumbo/libgumbo",
  "version": "0.10.1",
  "description": "PHP FFI wrapper for the Gumbo HTML5 parser.",
  "authors": [
    {
      "name": "Gumbo maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libgumbo\\Libgumbo",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-tags.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libgumbo": {
      "symbol_prefix": "gumbo",
      "library_names": [
        "libgumbo.dylib",
        "libgumbo.so",
        "gumbo.dll"
      ],
      "header_names": [
        "gumbo.h"
      ],
      "version": ">=0.10.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install gumbo-parser"
        ],
        "check_if_exists": [
          "brew list gumbo-parser"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libgumbo-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libgumbo.so"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libgumbo-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libgumbo.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add gumbo-parser-dev"
        ],
        "check_if_exists": [
          "apk info -e gumbo-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y gumbo-parser-devel"
        ],
        "check_if_exists": [
          "rpm -q gumbo-parser-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y gumbo-parser-devel"
        ],
        "check_if_exists": [
          "rpm -q gumbo-parser-devel"
        ]
      }
    }
  }
}
