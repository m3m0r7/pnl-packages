{
  "schema_version": "2026-07-01",
  "name": "libmpdecimal/libmpdecimal",
  "version": "4.0.1",
  "description": "PHP FFI wrapper for mpdecimal, the arbitrary-precision decimal library.",
  "authors": [
    {
      "name": "Libmpdecimal maintainers"
    }
  ],
  "license": "BSD-2-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libmpdecimal\\Libmpdecimal",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-radix.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "mpdecimal": {
      "symbol_prefix": "mpd",
      "library_names": [
        "libmpdec.dylib",
        "libmpdec.so",
        "mpdec.dll"
      ],
      "header_names": [
        "mpdecimal.h"
      ],
      "version": ">=2.5.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install mpdecimal"
        ],
        "check_if_exists": [
          "brew list mpdecimal"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libmpdec-dev"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libmpdec-dev"
        ]
      },
      "alpine": {
        "commands": [
          "apk add mpdecimal-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libmpdec"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y mpdecimal-devel"
        ]
      }
    }
  }
}
