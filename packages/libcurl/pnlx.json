{
  "schema_version": "2026-07-01",
  "name": "libcurl/libcurl",
  "version": "8.7.1",
  "description": "PHP FFI wrapper for libcurl HTTP client.",
  "authors": [
    {
      "name": "libcurl maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcurl\\Libcurl",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install curl"
      ],
      "checkIfExists": [
        "brew list curl"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libcurl4-openssl-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libcurl"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libcurl4-openssl-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libcurl"
      ]
    },
    "alpine": {
      "install": [
        "apk add curl-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libcurl"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libcurl-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libcurl"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libcurl-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libcurl"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install curl"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libcurl": {
      "symbol_prefix": "curl",
      "library_names": [
        "libcurl.dylib",
        "libcurl.so",
        "libcurl.dll"
      ],
      "header_names": [
        "curl/curl.h"
      ],
      "version": ">=7.0.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
