{
  "schema_version": "2026-07-01",
  "name": "libcurl/libcurl",
  "version": "8.7.1",
  "description": "PHP FFI wrapper for libcurl HTTP client.",
  "authors": [
    {
      "name": "libcurl maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libcurl\\Libcurl",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libcurl": {
      "symbol_prefix": "curl",
      "library_names": [
        "libcurl.dylib",
        "libcurl.so",
        "libcurl.dll"
      ],
      "header_names": [
        "curl/curl.h"
      ],
      "version": ">=7.0.0 & <9.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install curl"
        ],
        "check_if_exists": [
          "brew list curl"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libcurl4-openssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcurl"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libcurl4-openssl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcurl"
        ]
      },
      "alpine": {
        "commands": [
          "apk add curl-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libcurl"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libcurl-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libcurl"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libcurl-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libcurl"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install curl"
        ]
      }
    }
  }
}
