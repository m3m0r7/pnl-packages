{
  "schema_version": "2026-07-01",
  "name": "libhiredis/libhiredis",
  "version": "1.2.0",
  "description": "PHP FFI wrapper for the hiredis Redis client.",
  "authors": [
    {
      "name": "hiredis maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libhiredis\\Libhiredis",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-sds.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "hiredis": {
      "symbol_prefix": "redis",
      "library_names": [
        "libhiredis.dylib",
        "libhiredis.so",
        "hiredis.dll"
      ],
      "header_names": [
        "hiredis/hiredis.h"
      ],
      "version": ">=1.0.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install hiredis"
        ],
        "check_if_exists": [
          "brew list hiredis"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libhiredis-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hiredis"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libhiredis-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hiredis"
        ]
      },
      "alpine": {
        "commands": [
          "apk add hiredis-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists hiredis"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y hiredis-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists hiredis"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y hiredis-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists hiredis"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install hiredis"
        ]
      }
    }
  }
}
