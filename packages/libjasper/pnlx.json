{
  "schema_version": "2026-07-01",
  "name": "libjasper/libjasper",
  "version": "4.2.8",
  "description": "PHP FFI wrapper for JasPer, the JPEG-2000 codec library.",
  "authors": [ { "name": "Libjasper maintainers" } ],
  "license": "JasPer-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libjasper\\Libjasper",
  "examples": [ "EXAMPLES.md" ],
  "installation": {
    "darwin": { "install": [ "brew install jasper" ], "checkIfExists": [ "brew list jasper" ] },
    "ubuntu": { "install": [ "sudo apt-get install -y libjasper-dev" ] },
    "debian": { "install": [ "sudo apt-get install -y libjasper-dev" ] },
    "fedora": { "install": [ "sudo dnf install -y jasper-devel" ] }
  },
  "platforms": [
    { "os": "darwin", "arch": "aarch64" }, { "os": "darwin", "arch": "x86_64" },
    { "os": "linux", "arch": "x86_64" }, { "os": "linux", "arch": "aarch64" }
  ],
  "requires": {
    "jasper": {
      "symbol_prefix": "jas",
      "library_names": [ "libjasper.dylib", "libjasper.so", "jasper.dll" ],
      "header_names": [ "jasper/jasper.h" ],
      "version": ">=3.0.0 & <5.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
