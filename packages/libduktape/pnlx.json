{
  "schema_version": "2026-07-01",
  "name": "libduktape/libduktape",
  "version": "2.7.0",
  "description": "PHP FFI wrapper for the Duktape JavaScript engine.",
  "authors": [
    {
      "name": "Duktape maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libduktape\\Libduktape",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install duktape"
      ],
      "checkIfExists": [
        "brew list duktape"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libduktape-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libduktape.so"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libduktape-dev"
      ],
      "checkIfExists": [
        "ldconfig -p | grep -q libduktape.so"
      ]
    },
    "alpine": {
      "install": [
        "apk add duktape-dev"
      ],
      "checkIfExists": [
        "apk info -e duktape-dev"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y duktape-devel"
      ],
      "checkIfExists": [
        "rpm -q duktape-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y duktape-devel"
      ],
      "checkIfExists": [
        "rpm -q duktape-devel"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libduktape": {
      "symbol_prefix": "duk",
      "library_names": [
        "libduktape.dylib",
        "libduktape.so",
        "duktape.dll"
      ],
      "header_names": [
        "duktape.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
