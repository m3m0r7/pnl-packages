{
  "schema_version": "2026-07-01",
  "name": "libduktape/libduktape",
  "version": "2.7.0",
  "description": "PHP FFI wrapper for the Duktape JavaScript engine.",
  "authors": [
    {
      "name": "Duktape maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libduktape\\Libduktape",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-eval.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libduktape": {
      "symbol_prefix": "duk",
      "library_names": [
        "libduktape.dylib",
        "libduktape.so",
        "duktape.dll"
      ],
      "header_names": [
        "duktape.h"
      ],
      "version": ">=2.0.0 & <3.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install duktape"
        ],
        "check_if_exists": [
          "brew list duktape"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y duktape-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libduktape.so"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libduktape-dev"
        ],
        "check_if_exists": [
          "ldconfig -p | grep -q libduktape.so"
        ]
      },
      "alpine": {
        "commands": [
          "apk add duktape-dev"
        ],
        "check_if_exists": [
          "apk info -e duktape-dev"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y duktape-devel"
        ],
        "check_if_exists": [
          "rpm -q duktape-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y duktape-devel"
        ],
        "check_if_exists": [
          "rpm -q duktape-devel"
        ]
      }
    }
  }
}
