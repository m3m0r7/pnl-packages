{
  "schema_version": "2026-07-01",
  "name": "libxslt/libxslt",
  "version": "1.1.39",
  "description": "PHP FFI wrapper for the GNOME libxslt XSLT engine.",
  "authors": [
    {
      "name": "libxslt maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libxslt\\Libxslt",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-xinclude.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libxslt": {
      "symbol_prefix": "xslt",
      "library_names": [
        "libxslt.dylib",
        "libxslt.so",
        "libxslt.dll"
      ],
      "header_names": [
        "libxslt/xslt.h",
        "libxslt/transform.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libxslt"
        ],
        "check_if_exists": [
          "brew list libxslt"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libxslt1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxslt"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libxslt1-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxslt"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libxslt-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libxslt"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libxslt-devel"
        ],
        "check_if_exists": [
          "rpm -q libxslt-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libxslt-devel"
        ],
        "check_if_exists": [
          "rpm -q libxslt-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libxslt"
        ]
      }
    }
  }
}
