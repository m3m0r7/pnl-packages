{
  "schema_version": "2026-07-01",
  "name": "libxslt/libxslt",
  "version": "1.1.39",
  "description": "PHP FFI wrapper for the GNOME libxslt XSLT engine.",
  "authors": [
    {
      "name": "libxslt maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libxslt\\Libxslt",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libxslt"
      ],
      "checkIfExists": [
        "brew list libxslt"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libxslt1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxslt"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libxslt1-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxslt"
      ]
    },
    "alpine": {
      "install": [
        "apk add libxslt-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libxslt"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libxslt-devel"
      ],
      "checkIfExists": [
        "rpm -q libxslt-devel"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libxslt-devel"
      ],
      "checkIfExists": [
        "rpm -q libxslt-devel"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libxslt"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libxslt": {
      "symbol_prefix": "xslt",
      "library_names": [
        "libxslt.dylib",
        "libxslt.so",
        "libxslt.dll"
      ],
      "header_names": [
        "libxslt/xslt.h",
        "libxslt/transform.h"
      ],
      "version": ">=1.1.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
