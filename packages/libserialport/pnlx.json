{
  "schema_version": "2026-07-01",
  "name": "libserialport/libserialport",
  "version": "0.1.1",
  "description": "PHP FFI wrapper for libserialport serial I/O.",
  "authors": [
    {
      "name": "libserialport maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libserialport\\Libserialport",
  "examples": [
    "EXAMPLES.md"
  ],
  "installation": {
    "darwin": {
      "install": [
        "brew install libserialport"
      ],
      "checkIfExists": [
        "brew list libserialport"
      ]
    },
    "ubuntu": {
      "install": [
        "sudo apt-get install -y libserialport-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libserialport"
      ]
    },
    "debian": {
      "install": [
        "sudo apt-get install -y libserialport-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libserialport"
      ]
    },
    "alpine": {
      "install": [
        "apk add libserialport-dev"
      ],
      "checkIfExists": [
        "pkg-config --exists libserialport"
      ]
    },
    "fedora": {
      "install": [
        "sudo dnf install -y libserialport-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libserialport"
      ]
    },
    "rhel": {
      "install": [
        "sudo dnf install -y libserialport-devel"
      ],
      "checkIfExists": [
        "pkg-config --exists libserialport"
      ]
    },
    "windows": {
      "install": [
        "vcpkg install libserialport"
      ]
    }
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "requires": {
    "libserialport": {
      "symbol_prefix": "sp",
      "library_names": [
        "libserialport.dylib",
        "libserialport.so",
        "serialport.dll"
      ],
      "header_names": [
        "libserialport.h"
      ],
      "version": ">=0.1.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {}
}
