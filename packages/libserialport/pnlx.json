{
  "schema_version": "2026-07-01",
  "name": "libserialport/libserialport",
  "version": "0.1.1",
  "description": "PHP FFI wrapper for libserialport serial I/O.",
  "authors": [
    {
      "name": "libserialport maintainers"
    }
  ],
  "license": "LGPL-3.0-or-later",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libserialport\\Libserialport",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-version.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64",
      "libc": "glibc"
    },
    {
      "os": "linux",
      "arch": "aarch64",
      "libc": "glibc"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "libserialport": {
      "symbol_prefix": "sp",
      "library_names": [
        "libserialport.dylib",
        "libserialport.so",
        "serialport.dll"
      ],
      "header_names": [
        "libserialport.h"
      ],
      "version": ">=0.1.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libserialport"
        ],
        "check_if_exists": [
          "brew list libserialport"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libserialport-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libserialport"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libserialport-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libserialport"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libserialport-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists libserialport"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libserialport-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libserialport"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libserialport-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists libserialport"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install libserialport"
        ]
      }
    }
  }
}
