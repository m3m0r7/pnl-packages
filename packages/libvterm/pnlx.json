{
  "schema_version": "2026-07-01",
  "name": "libvterm/libvterm",
  "version": "0.3.3",
  "description": "PHP FFI wrapper for libvterm VT220/xterm terminal emulation.",
  "authors": [
    {
      "name": "libvterm maintainers"
    }
  ],
  "license": "MIT",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libvterm\\Libvterm",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-attr-types.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "vterm": {
      "symbol_prefix": "vterm",
      "library_names": [
        "libvterm.dylib",
        "libvterm.so"
      ],
      "header_names": [
        "vterm.h"
      ],
      "version": ">=0.3.0 & <1.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install libvterm"
        ],
        "check_if_exists": [
          "brew list libvterm"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libvterm-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vterm"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libvterm-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vterm"
        ]
      },
      "alpine": {
        "commands": [
          "apk add libvterm-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists vterm"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y libvterm-devel"
        ],
        "check_if_exists": [
          "rpm -q libvterm-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y libvterm-devel"
        ],
        "check_if_exists": [
          "rpm -q libvterm-devel"
        ]
      }
    }
  }
}
