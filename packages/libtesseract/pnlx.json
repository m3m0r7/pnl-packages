{
  "schema_version": "2026-07-01",
  "name": "libtesseract/libtesseract",
  "version": "5.5.0",
  "description": "PHP FFI wrapper for the Tesseract OCR engine C API.",
  "authors": [
    {
      "name": "Libtesseract maintainers"
    }
  ],
  "license": "Apache-2.0",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libtesseract\\Libtesseract",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-engine-modes.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    }
  ],
  "native_libraries": {
    "tesseract": {
      "symbol_prefix": "Tess",
      "library_names": [
        "libtesseract.dylib",
        "libtesseract.so",
        "tesseract.dll"
      ],
      "header_names": [
        "tesseract/capi.h"
      ],
      "version": ">=5.0.0 & <6.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install tesseract"
        ],
        "check_if_exists": [
          "brew list tesseract"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libtesseract-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists tesseract"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libtesseract-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists tesseract"
        ]
      },
      "alpine": {
        "commands": [
          "apk add tesseract-ocr-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists tesseract"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y tesseract-devel"
        ],
        "check_if_exists": [
          "pkg-config --exists tesseract"
        ]
      }
    }
  }
}
