{
  "schema_version": "2026-07-01",
  "name": "libspeex/libspeex",
  "version": "1.2.1",
  "description": "PHP FFI wrapper for the Speex speech audio codec.",
  "authors": [
    {
      "name": "Xiph.Org / Speex maintainers"
    }
  ],
  "license": "BSD-3-Clause",
  "entrypoint": "src/generated/index.php",
  "class": "Pnlx\\Libspeex\\Libspeex",
  "examples": [
    "EXAMPLES.md",
    "EXAMPLES-bits.md"
  ],
  "platforms": [
    {
      "os": "darwin",
      "arch": "aarch64"
    },
    {
      "os": "darwin",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "x86_64"
    },
    {
      "os": "linux",
      "arch": "aarch64"
    },
    {
      "os": "windows",
      "arch": "x86_64"
    }
  ],
  "native_libraries": {
    "speex": {
      "symbol_prefix": "speex",
      "library_names": [
        "libspeex.dylib",
        "libspeex.so",
        "speex.dll"
      ],
      "header_names": [
        "speex/speex.h"
      ],
      "version": ">=1.2.0 & <2.0.0",
      "required": true
    }
  },
  "dependencies": {},
  "setup": {
    "install": {
      "darwin": {
        "commands": [
          "brew install speex"
        ],
        "check_if_exists": [
          "brew list speex"
        ]
      },
      "ubuntu": {
        "commands": [
          "sudo apt-get install -y libspeex-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists speex"
        ]
      },
      "debian": {
        "commands": [
          "sudo apt-get install -y libspeex-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists speex"
        ]
      },
      "alpine": {
        "commands": [
          "apk add speex-dev"
        ],
        "check_if_exists": [
          "pkg-config --exists speex"
        ]
      },
      "fedora": {
        "commands": [
          "sudo dnf install -y speex-devel"
        ],
        "check_if_exists": [
          "rpm -q speex-devel"
        ]
      },
      "rhel": {
        "commands": [
          "sudo dnf install -y speex-devel"
        ],
        "check_if_exists": [
          "rpm -q speex-devel"
        ]
      },
      "windows": {
        "commands": [
          "vcpkg install speex"
        ]
      }
    }
  }
}
